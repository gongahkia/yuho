rel economic_development_claim -["contradicts"]-> private_transfer_claim;
rel kelo_decision -["corroborates"]-> economic_development_claim;
rel judicial_deference_claim -["corroborates"]-> economic_development_claim;
rel kelo_decision -["supersedes"]-> condemnation_dispute;
