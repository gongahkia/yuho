timeline gideon_case {
    kind: linear,
    start: 1961-06-03,
    end: 1963-03-18,
}

entity poolroom_charge : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Gideon v. Wainwright, 372 U.S. 335",
    summary: "Clarence Earl Gideon was charged in Florida state court with a noncapital felony.",
    appears_on: gideon_case @ 1961-06-03..1961-12-31,
}

entity counsel_request_denied : fact {
    reference_source: "GovInfo U.S. Reports",
