}

entity gideon_decision : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Gideon v. Wainwright, 372 U.S. 335",
    summary: "The Court reversed and held appointed counsel fundamental for indigent felony defendants.",
    appears_on: gideon_case @ 1963-03-18..1963-03-18,
}

