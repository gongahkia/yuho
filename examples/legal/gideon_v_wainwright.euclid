    position: "Appointment of counsel in state felony cases could depend on special circumstances.",
    appears_on: gideon_case @ 1961-06-03..1963-03-18,
}

entity indigent_counsel_claim : claim {
    narrative: "petitioner",
    reference_source: "GovInfo U.S. Reports",
    citation: "Gideon v. Wainwright holding",
    position: "Counsel is fundamental and essential to a fair felony trial for indigent defendants.",
