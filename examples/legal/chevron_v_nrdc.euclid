timeline chevron_case {
    kind: linear,
    start: 1981-01-01,
    end: 1984-06-25,
}

entity epa_bubble_rule : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC, 467 U.S. 837",
    summary: "EPA regulations allowed a plantwide bubble definition for stationary source permitting.",
    appears_on: chevron_case @ 1981-01-01..1981-12-31,
}

entity dc_circuit_set_aside : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC, 467 U.S. 837",
    summary: "The D.C. Circuit set aside regulations embodying the bubble concept.",
    appears_on: chevron_case @ 1982-01-01..1983-05-31,
}

entity cert_granted : fact {
