    summary: "The Supreme Court granted review.",
    appears_on: chevron_case @ 1983-05-31..1983-05-31,
}

entity supreme_court_argument : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC, 467 U.S. 837",
    summary: "The Supreme Court heard argument.",
    appears_on: chevron_case @ 1984-02-29..1984-02-29,
}

entity chevron_decision : fact {
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC, 467 U.S. 837",
    summary: "The Court upheld EPA's reasonable construction of ambiguous Clean Air Act text.",
    appears_on: chevron_case @ 1984-06-25..1984-06-25,
}

entity us_reports_chevron : evidence {
    citation: "Chevron U.S.A. v. Natural Resources Defense Council, 467 U.S. 837",
