    url: "https://www.govinfo.gov/app/details/USREPORTS-467/USREPORTS-467-837",
    admissibility: "public court record",
    appears_on: chevron_case @ 1984-06-25..1984-06-25,
}

entity chevron_opinion_exhibit : exhibit {
    number: "CHEV-1",
    description: "GovInfo U.S. Reports record for Chevron",
    appears_on: chevron_case @ 1984-06-25..1984-06-25,
}

entity agency_deference_claim : claim {
    narrative: "agency",
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC holding",
    position: "Courts should defer to a reasonable agency interpretation when Congress leaves statutory ambiguity.",
    appears_on: chevron_case @ 1981-01-01..1984-06-25,
}

entity clean_air_purpose_claim : claim {
    narrative: "challenger",
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC court-of-appeals posture",
    position: "The nonattainment program's air-quality purpose made the plantwide source definition inappropriate.",
    appears_on: chevron_case @ 1981-01-01..1984-06-25,
}

entity two_step_review_claim : claim {
    narrative: "court",
    reference_source: "GovInfo U.S. Reports",
    citation: "Chevron U.S.A. v. NRDC reasoning",
    position: "Judicial review asks first whether Congress spoke clearly and then whether the agency answer is reasonable.",
    appears_on: chevron_case @ 1984-06-25..1984-06-25,
}

rel us_reports_chevron -["cites"]-> epa_bubble_rule;
rel us_reports_chevron -["cites"]-> dc_circuit_set_aside;
rel us_reports_chevron -["cites"]-> cert_granted;
