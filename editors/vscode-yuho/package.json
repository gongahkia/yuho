{
  "name": "yuho",
  "displayName": "Yuho",
  "description": "Language server, syntax highlighting, snippets, and commands for the Yuho legal DSL (Singapore Penal Code).",
  "version": "0.4.0",
  "publisher": "yuho",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Linters", "Snippets"],
  "activationEvents": [
    "onLanguage:yuho",
    "workspaceContains:**/*.yh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "yuho",
      "aliases": ["Yuho", "yh"],
      "extensions": [".yh"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "yuho",
      "scopeName": "source.yuho",
      "path": "./syntaxes/yuho.tmLanguage.json"
    }],
    "snippets": [{
      "language": "yuho",
      "path": "./snippets/yuho.json"
    }],
    "commands": [
      {
        "command": "yuho.openSSO",
        "title": "Yuho: Open SSO page for section under cursor"
      },
      {
        "command": "yuho.check",
        "title": "Yuho: Run check on active file"
      },
      {
        "command": "yuho.transpileMermaid",
        "title": "Yuho: Transpile to Mermaid → open preview"
      },
      {
        "command": "yuho.transpileEnglish",
        "title": "Yuho: Transpile to plain English"
      },
      {
        "command": "yuho.showCoverage",
        "title": "Yuho: Show coverage dashboard"
      },
      {
        "command": "yuho.openLibrarySection",
        "title": "Yuho: Open library section"
      },
      {
        "command": "yuho.refreshTreeView",
        "title": "Yuho: Refresh library tree",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yuho-library",
          "title": "Yuho Library",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "yuho-library": [
        {
          "id": "yuho.libraryTree",
          "name": "Penal Code 1871",
          "icon": "$(book)",
          "contextualTitle": "Yuho — Penal Code 1871"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "yuho.refreshTreeView",
          "when": "view == yuho.libraryTree",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "editorLangId == yuho",
          "command": "yuho.openSSO",
          "group": "yuho@1"
        },
        {
          "when": "editorLangId == yuho",
          "command": "yuho.transpileMermaid",
          "group": "yuho@2"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Yuho",
      "properties": {
        "yuho.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Launch the `yuho lsp` server on activation."
        },
        "yuho.lsp.command": {
          "type": "string",
          "default": "",
          "description": "Path to the `yuho` executable. Leave empty to auto-resolve: prefers `<workspace>/.venv-lsp/bin/yuho` (the project's pygls venv), falls back to `yuho` on PATH."
        },
        "yuho.lsp.args": {
          "type": "array",
          "default": ["lsp", "--workspace"],
          "items": { "type": "string" },
          "description": "Arguments passed to the `yuho` binary to start the LSP server. The default `--workspace` flag enables whole-library diagnostic walks on startup."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
