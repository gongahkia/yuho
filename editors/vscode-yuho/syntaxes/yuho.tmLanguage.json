{
  "name": "Yuho",
  "scopeName": "source.yuho",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.yuho",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.yuho",
          "match": "//.*$"
        },
        {
          "name": "comment.block.yuho",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.yuho",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.yuho",
              "match": "\\\\(?:[\\\\'\"nbrt0]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.money.yuho",
          "match": "\\b(?:SGD|USD|EUR|GBP|JPY|CNY|INR|AUD)\\s*[0-9][0-9,]*(?:\\.[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.percent.yuho",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?%"
        },
        {
          "name": "constant.numeric.date.yuho",
          "match": "\\b[0-9]{4}-[0-9]{2}-[0-9]{2}\\b"
        },
        {
          "name": "constant.numeric.duration.yuho",
          "match": "\\b[0-9]+\\s+(?:years?|months?|days?|hours?|minutes?|seconds?)\\b"
        },
        {
          "name": "constant.numeric.yuho",
          "match": "\\b-?[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yuho",
          "match": "\\b(?:if|match|case|return|pass|consequence)\\b"
        },
        {
          "name": "keyword.declaration.yuho",
          "match": "\\b(?:struct|enum|type|fn|statute|import|from|referencing)\\b"
        },
        {
          "name": "keyword.other.legal.yuho",
          "match": "\\b(?:definitions|elements|penalty|illustration|interpretations|interpretation|citation|court|endorsement|binding|persuasive|none|treatment|followed|distinguished|overruled|exceptions|case_law|jurisdiction|subsumes|amends|effective|repealed|imprisonment|fine|supplementary|actus_reus|mens_rea|circumstance|all_of|any_of|none_of|when|priority|defeats|rebuts|undercuts)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.yuho",
          "match": "\\b(?:int|float|bool|string|money|percent|date|duration|void)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "entity.name.function.yuho",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.yuho"
            }
          }
        },
        {
          "name": "entity.name.type.struct.yuho",
          "match": "\\bstruct\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.struct.yuho"
            }
          }
        },
        {
          "name": "constant.numeric.section.yuho",
          "match": "\\b(?:s[0-9][0-9A-Z]*|[0-9][0-9A-Z]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.yuho",
          "match": ":="
        },
        {
          "name": "keyword.operator.range.yuho",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.logical.yuho",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.yuho",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.yuho",
          "match": "\\+|-|\\*|/|%"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.yuho",
          "match": "\\b(?:TRUE|FALSE)\\b"
        }
      ]
    }
  }
}
