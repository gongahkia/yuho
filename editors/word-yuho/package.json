{
  "name": "yuho-word",
  "version": "0.1.0",
  "description": "Yuho Word add-in: insert structured Singapore Penal Code references and English transpilations into Word.",
  "author": "Gabriel Ong Zhe Mian <gabrielzmong@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:data": "python3 ../../scripts/build_corpus.py && python3 ../browser-yuho/build_data.py && rm -rf ./data && cp -r ../browser-yuho/data ./",
    "build:manifest:prod": "python3 build_manifest.py --host https://yuho.dev/word",
    "rebuild": "npm run build:data",
    "dev:server": "node dev_server.js",
    "dev:certs": "office-addin-dev-certs install",
    "start": "concurrently --raw \"npm:dev:server\" \"office-addin-debugging start manifest.xml\"",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0"
  }
}
