// Test file for s507_criminal_intimidation_anonymous_communication
// Yuho v5 Syntax

referencing penal_code/s507_criminal_intimidation_anonymous_communication

struct AnonymousIntimidationCaseTest {
    bool elementsSatisfied,
}

AnonymousIntimidationCaseTest positive := AnonymousIntimidationCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

AnonymousIntimidationCaseTest negative := AnonymousIntimidationCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
