// Test file for s466_forgery_record_court_justice_public_register

referencing penal_code/s466_forgery_record_court_justice_public_register

struct ForgeryRecordCourtJusticeTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

ForgeryRecordCourtJusticeTestCase guilty := ForgeryRecordCourtJusticeTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_forgery_record_court_justice(guilty.elements_satisfied, guilty.defence_applies) == TRUE

ForgeryRecordCourtJusticeTestCase defended := ForgeryRecordCourtJusticeTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_forgery_record_court_justice(defended.elements_satisfied, defended.defence_applies) == FALSE

ForgeryRecordCourtJusticeTestCase notMadeOut := ForgeryRecordCourtJusticeTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_forgery_record_court_justice(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
