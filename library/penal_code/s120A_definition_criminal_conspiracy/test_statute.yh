// Test file for s120A_definition_criminal_conspiracy
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s120A_definition_criminal_conspiracy

struct DefinitionCriminalConspiracyTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
DefinitionCriminalConspiracyTestCase guilty := DefinitionCriminalConspiracyTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_definition_criminal_conspiracy(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
DefinitionCriminalConspiracyTestCase defended := DefinitionCriminalConspiracyTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_definition_criminal_conspiracy(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
DefinitionCriminalConspiracyTestCase notMadeOut := DefinitionCriminalConspiracyTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_definition_criminal_conspiracy(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
