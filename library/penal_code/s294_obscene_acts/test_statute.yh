// Test file for s294_obscene_acts
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s294_obscene_acts

struct ObsceneActsTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
ObsceneActsTestCase guilty := ObsceneActsTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_obscene_acts(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
ObsceneActsTestCase defended := ObsceneActsTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_obscene_acts(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
ObsceneActsTestCase notMadeOut := ObsceneActsTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_obscene_acts(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
