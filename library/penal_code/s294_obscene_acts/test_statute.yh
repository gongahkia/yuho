// Test file for s294
// Yuho v5 Syntax

referencing penal_code/s294_obscene_acts

struct S294CaseTestCase {
    bool annoyanceOfOthers,
    bool publicObscenity,
}

S294CaseTestCase matching := S294CaseTestCase {
    annoyanceOfOthers := TRUE,
    publicObscenity := TRUE,
}

assert applies_s294(matching.annoyanceOfOthers, matching.publicObscenity) == TRUE

S294CaseTestCase missing := S294CaseTestCase {
    annoyanceOfOthers := FALSE,
    publicObscenity := TRUE,
}

assert applies_s294(missing.annoyanceOfOthers, missing.publicObscenity) == FALSE
