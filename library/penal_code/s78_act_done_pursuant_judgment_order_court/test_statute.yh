// Test file for s78_act_done_pursuant_judgment_order_court
// Yuho v5 Syntax

referencing penal_code/s78_act_done_pursuant_judgment_order_court

struct CourtOrderTestCase {
    bool pursuantToJudgment,
    bool judgmentInForce,
    bool goodFaithBelievedJurisdiction,
}

// bailiff executing a writ in force, believing jurisdiction: defence applies
CourtOrderTestCase bailiffWithBelief := CourtOrderTestCase {
    pursuantToJudgment := TRUE,
    judgmentInForce := TRUE,
    goodFaithBelievedJurisdiction := TRUE,
}

assert court_order_defence(bailiffWithBelief.pursuantToJudgment, bailiffWithBelief.judgmentInForce, bailiffWithBelief.goodFaithBelievedJurisdiction) == TRUE

// judgment reversed before act: defence fails
CourtOrderTestCase judgmentReversed := CourtOrderTestCase {
    pursuantToJudgment := TRUE,
    judgmentInForce := FALSE,
    goodFaithBelievedJurisdiction := TRUE,
}

assert court_order_defence(judgmentReversed.pursuantToJudgment, judgmentReversed.judgmentInForce, judgmentReversed.goodFaithBelievedJurisdiction) == FALSE

// act not pursuant to any order: defence fails
CourtOrderTestCase notPursuant := CourtOrderTestCase {
    pursuantToJudgment := FALSE,
    judgmentInForce := TRUE,
    goodFaithBelievedJurisdiction := TRUE,
}

assert court_order_defence(notPursuant.pursuantToJudgment, notPursuant.judgmentInForce, notPursuant.goodFaithBelievedJurisdiction) == FALSE
