// Test file for s182_false_information_intent_cause_public

referencing penal_code/s182_false_information_intent_cause_public

struct FalseInformationIntentCauseTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

FalseInformationIntentCauseTestCase guilty := FalseInformationIntentCauseTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_false_information_intent_cause(guilty.elements_satisfied, guilty.defence_applies) == TRUE

FalseInformationIntentCauseTestCase defended := FalseInformationIntentCauseTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_false_information_intent_cause(defended.elements_satisfied, defended.defence_applies) == FALSE

FalseInformationIntentCauseTestCase notMadeOut := FalseInformationIntentCauseTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_false_information_intent_cause(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
