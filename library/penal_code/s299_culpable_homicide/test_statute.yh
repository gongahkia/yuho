// Test file for s299_culpable_homicide

referencing penal_code/s299_culpable_homicide


struct CulpableHomicideTestCase {
    string actusReus,
    bool deathCaused,
    string mensRea,
}


CulpableHomicideTestCase intentionDeath := CulpableHomicideTestCase {
    actusReus := "act",
    deathCaused := TRUE,
    mensRea := "intention_to_cause_death",
}

assert intentionDeath.actusReus == "act"
assert intentionDeath.deathCaused == TRUE
assert intentionDeath.mensRea == "intention_to_cause_death"
assert is_culpable_homicide(intentionDeath.actusReus, intentionDeath.deathCaused, intentionDeath.mensRea) == TRUE


CulpableHomicideTestCase intentionInjury := CulpableHomicideTestCase {
    actusReus := "act",
    deathCaused := TRUE,
    mensRea := "intention_to_cause_bodily_injury",
}

assert intentionInjury.mensRea == "intention_to_cause_bodily_injury"
assert is_culpable_homicide(intentionInjury.actusReus, intentionInjury.deathCaused, intentionInjury.mensRea) == TRUE


CulpableHomicideTestCase knowledgeDeath := CulpableHomicideTestCase {
    actusReus := "act",
    deathCaused := TRUE,
    mensRea := "knowledge_likely_to_cause_death",
}

assert knowledgeDeath.mensRea == "knowledge_likely_to_cause_death"
assert is_culpable_homicide(knowledgeDeath.actusReus, knowledgeDeath.deathCaused, knowledgeDeath.mensRea) == TRUE


CulpableHomicideTestCase noActusReus := CulpableHomicideTestCase {
    actusReus := "none",
    deathCaused := TRUE,
    mensRea := "intention_to_cause_death",
}

assert noActusReus.actusReus == "none"
assert is_culpable_homicide(noActusReus.actusReus, noActusReus.deathCaused, noActusReus.mensRea) == FALSE


CulpableHomicideTestCase noDeathCaused := CulpableHomicideTestCase {
    actusReus := "act",
    deathCaused := FALSE,
    mensRea := "intention_to_cause_death",
}

assert noDeathCaused.deathCaused == FALSE
assert is_culpable_homicide(noDeathCaused.actusReus, noDeathCaused.deathCaused, noDeathCaused.mensRea) == FALSE


CulpableHomicideTestCase noMensRea := CulpableHomicideTestCase {
    actusReus := "act",
    deathCaused := TRUE,
    mensRea := "negligence",
}

assert noMensRea.mensRea == "negligence"
assert is_culpable_homicide(noMensRea.actusReus, noMensRea.deathCaused, noMensRea.mensRea) == FALSE


CulpableHomicideTestCase omissionCase := CulpableHomicideTestCase {
    actusReus := "omission",
    deathCaused := TRUE,
    mensRea := "intention_to_cause_death",
}

assert omissionCase.actusReus == "omission"
assert omissionCase.deathCaused == TRUE
assert is_culpable_homicide(omissionCase.actusReus, omissionCase.deathCaused, omissionCase.mensRea) == TRUE
