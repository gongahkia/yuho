// Test file for s387_putting_person_fear_death_grievous_hurt
// Yuho v5 Syntax

referencing penal_code/s387_putting_person_fear_death_grievous_hurt

struct S387TestCase {
    bool extortionIntent,
    bool fearOfDeathOrGrievousHurt,
}

S387TestCase threat := S387TestCase {
    extortionIntent := TRUE,
    fearOfDeathOrGrievousHurt := TRUE,
}

assert s387_applies(threat.extortionIntent, threat.fearOfDeathOrGrievousHurt) == TRUE

S387TestCase missingIntent := S387TestCase {
    extortionIntent := FALSE,
    fearOfDeathOrGrievousHurt := TRUE,
}

assert s387_applies(missingIntent.extortionIntent, missingIntent.fearOfDeathOrGrievousHurt) == FALSE
