// Test file for s317_exposure_abandonment_child_below_12_years
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s317_exposure_abandonment_child_below_12_years

struct ExposureAbandonmentChildBelowTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
ExposureAbandonmentChildBelowTestCase guilty := ExposureAbandonmentChildBelowTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_exposure_abandonment_child_below(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
ExposureAbandonmentChildBelowTestCase defended := ExposureAbandonmentChildBelowTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_exposure_abandonment_child_below(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
ExposureAbandonmentChildBelowTestCase notMadeOut := ExposureAbandonmentChildBelowTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_exposure_abandonment_child_below(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
