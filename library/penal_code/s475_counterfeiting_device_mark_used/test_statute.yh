// Test file for s475_counterfeiting_device_mark_used
// Yuho v5 Syntax

referencing penal_code/s475_counterfeiting_device_mark_used

struct CounterfeitMarkS467CaseTest {
    bool elementsSatisfied,
}

CounterfeitMarkS467CaseTest positive := CounterfeitMarkS467CaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

CounterfeitMarkS467CaseTest negative := CounterfeitMarkS467CaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
