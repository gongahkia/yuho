// Test file for s277_fouling_water_public_spring_reservoir
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s277_fouling_water_public_spring_reservoir

struct FoulingWaterPublicSpringTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
FoulingWaterPublicSpringTestCase guilty := FoulingWaterPublicSpringTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_fouling_water_public_spring(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
FoulingWaterPublicSpringTestCase defended := FoulingWaterPublicSpringTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_fouling_water_public_spring(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
FoulingWaterPublicSpringTestCase notMadeOut := FoulingWaterPublicSpringTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_fouling_water_public_spring(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
