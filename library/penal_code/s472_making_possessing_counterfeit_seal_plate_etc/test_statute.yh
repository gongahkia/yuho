// Test file for s472_making_possessing_counterfeit_seal_plate_etc
// Yuho v5 Syntax

referencing penal_code/s472_making_possessing_counterfeit_seal_plate_etc

struct CounterfeitSealS467CaseTest {
    bool elementsSatisfied,
}

CounterfeitSealS467CaseTest positive := CounterfeitSealS467CaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

CounterfeitSealS467CaseTest negative := CounterfeitSealS467CaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
