// Test file for s500_punishment_defamation
// Yuho v5 Syntax

referencing penal_code/s500_punishment_defamation

struct DefamationPunishmentCaseTest {
    bool offenceCommitted,
}

DefamationPunishmentCaseTest convicted := DefamationPunishmentCaseTest {
    offenceCommitted := TRUE,
}

assert convicted.offenceCommitted == TRUE
assert punishment_applies(convicted.offenceCommitted) == TRUE

DefamationPunishmentCaseTest acquitted := DefamationPunishmentCaseTest {
    offenceCommitted := FALSE,
}

assert acquitted.offenceCommitted == FALSE
assert punishment_applies(acquitted.offenceCommitted) == FALSE
