/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr500-#pr500-

referencing penal_code/s499_defamation

statute 500 "Punishment for defamation" effective 1872-01-01 {
    /// Punishment for the offence of defamation under section 499.
    penalty or_both {
        imprisonment := 0 days .. 2 years;
        fine := unlimited;
    }
}
