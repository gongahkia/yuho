// Test file for s461_dishonestly_breaking_open_closed_receptacle
// Yuho v5 Syntax

referencing penal_code/s461_dishonestly_breaking_open_closed_receptacle

struct BreakingReceptacleCaseTest {
    bool elementsSatisfied,
}

BreakingReceptacleCaseTest positive := BreakingReceptacleCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

BreakingReceptacleCaseTest negative := BreakingReceptacleCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
