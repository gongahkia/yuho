// Test file for s441_criminal_trespass

referencing penal_code/s441_criminal_trespass

struct CriminalTrespassTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CriminalTrespassTestCase guilty := CriminalTrespassTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_criminal_trespass(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CriminalTrespassTestCase defended := CriminalTrespassTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_criminal_trespass(defended.elements_satisfied, defended.defence_applies) == FALSE

CriminalTrespassTestCase notMadeOut := CriminalTrespassTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_criminal_trespass(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
