// Test file for s308
// Yuho v5 Syntax

referencing penal_code/s308_attempt_commit_culpable_homicide

struct S308CaseTestCase {
    bool actDone,
    bool intentionCausingDeath,
    bool wouldBeCulpableHomicideNotMurder,
}

S308CaseTestCase matching := S308CaseTestCase {
    actDone := TRUE,
    intentionCausingDeath := TRUE,
    wouldBeCulpableHomicideNotMurder := TRUE,
}

assert applies_s308(matching.actDone, matching.intentionCausingDeath, matching.wouldBeCulpableHomicideNotMurder) == TRUE

S308CaseTestCase missing := S308CaseTestCase {
    actDone := FALSE,
    intentionCausingDeath := TRUE,
    wouldBeCulpableHomicideNotMurder := TRUE,
}

assert applies_s308(missing.actDone, missing.intentionCausingDeath, missing.wouldBeCulpableHomicideNotMurder) == FALSE
