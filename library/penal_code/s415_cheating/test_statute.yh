// Test file for s415_cheating

referencing penal_code/s415_cheating


struct CheatingTestCase {
    string deceptionType,
    string inducementType,
    bool causesDamageHarm,
}


CheatingTestCase fraudulentCheating := CheatingTestCase {
    deceptionType := "fraudulently",
    inducementType := "delivery_of_property",
    causesDamageHarm := TRUE,
}

assert fraudulentCheating.deceptionType == "fraudulently"
assert fraudulentCheating.inducementType == "delivery_of_property"
assert fraudulentCheating.causesDamageHarm == TRUE
assert is_fraudulent(fraudulentCheating.deceptionType) == TRUE
assert is_dishonest(fraudulentCheating.deceptionType) == FALSE
assert evaluate_cheating(fraudulentCheating.deceptionType, fraudulentCheating.inducementType, fraudulentCheating.causesDamageHarm) == "Said to cheat"


CheatingTestCase dishonestCheating := CheatingTestCase {
    deceptionType := "dishonestly",
    inducementType := "consent_to_retain",
    causesDamageHarm := TRUE,
}

assert dishonestCheating.deceptionType == "dishonestly"
assert is_dishonest(dishonestCheating.deceptionType) == TRUE
assert is_fraudulent(dishonestCheating.deceptionType) == FALSE
assert evaluate_cheating(dishonestCheating.deceptionType, dishonestCheating.inducementType, dishonestCheating.causesDamageHarm) == "Said to cheat"


CheatingTestCase noDeception := CheatingTestCase {
    deceptionType := "none",
    inducementType := "delivery_of_property",
    causesDamageHarm := TRUE,
}

assert noDeception.deceptionType == "none"
assert is_fraudulent(noDeception.deceptionType) == FALSE
assert is_dishonest(noDeception.deceptionType) == FALSE
assert evaluate_cheating(noDeception.deceptionType, noDeception.inducementType, noDeception.causesDamageHarm) == "Not cheating - no deception"


CheatingTestCase noInducement := CheatingTestCase {
    deceptionType := "fraudulently",
    inducementType := "none",
    causesDamageHarm := TRUE,
}

assert noInducement.inducementType == "none"
assert evaluate_cheating(noInducement.deceptionType, noInducement.inducementType, noInducement.causesDamageHarm) == "Not cheating - no inducement"


CheatingTestCase noHarm := CheatingTestCase {
    deceptionType := "fraudulently",
    inducementType := "delivery_of_property",
    causesDamageHarm := FALSE,
}

assert noHarm.causesDamageHarm == FALSE
assert evaluate_cheating(noHarm.deceptionType, noHarm.inducementType, noHarm.causesDamageHarm) == "Not said to cheat"
