// Test file for s322_voluntarily_causing_grievous_hurt

referencing penal_code/s322_voluntarily_causing_grievous_hurt

struct S322Scenario {
    bool voluntarilyCausesHurt,
    bool intendsOrKnowsGrievous,
    bool actuallyGrievous,
    string grievousKindIntended,
    string grievousKindCaused,
    bool defenceApplies,
}


S322Scenario intentBlindingCauseBlinding := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := TRUE,
    actuallyGrievous := TRUE,
    grievousKindIntended := "permanent_privation_of_sight",
    grievousKindCaused := "permanent_privation_of_sight",
    defenceApplies := FALSE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    intentBlindingCauseBlinding.voluntarilyCausesHurt && intentBlindingCauseBlinding.intendsOrKnowsGrievous && intentBlindingCauseBlinding.actuallyGrievous,
    intentBlindingCauseBlinding.defenceApplies
) == TRUE


S322Scenario knowsLikelyGrievousFracture := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := TRUE,
    actuallyGrievous := TRUE,
    grievousKindIntended := "fracture_or_dislocation_of_a_bone",
    grievousKindCaused := "fracture_or_dislocation_of_a_bone",
    defenceApplies := FALSE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    knowsLikelyGrievousFracture.voluntarilyCausesHurt && knowsLikelyGrievousFracture.intendsOrKnowsGrievous && knowsLikelyGrievousFracture.actuallyGrievous,
    knowsLikelyGrievousFracture.defenceApplies
) == TRUE


S322Scenario kindShift := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := TRUE,
    actuallyGrievous := TRUE,
    grievousKindIntended := "fracture_or_dislocation_of_a_bone",
    grievousKindCaused := "permanent_privation_of_sight",
    defenceApplies := FALSE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    kindShift.voluntarilyCausesHurt && kindShift.intendsOrKnowsGrievous && kindShift.actuallyGrievous,
    kindShift.defenceApplies
) == TRUE


S322Scenario nonGrievousIntent := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := FALSE,
    actuallyGrievous := FALSE,
    grievousKindIntended := "none",
    grievousKindCaused := "none",
    defenceApplies := FALSE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    nonGrievousIntent.voluntarilyCausesHurt && nonGrievousIntent.intendsOrKnowsGrievous && nonGrievousIntent.actuallyGrievous,
    nonGrievousIntent.defenceApplies
) == FALSE


S322Scenario intentWithoutResult := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := TRUE,
    actuallyGrievous := FALSE,
    grievousKindIntended := "fracture_or_dislocation_of_a_bone",
    grievousKindCaused := "none",
    defenceApplies := FALSE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    intentWithoutResult.voluntarilyCausesHurt && intentWithoutResult.intendsOrKnowsGrievous && intentWithoutResult.actuallyGrievous,
    intentWithoutResult.defenceApplies
) == FALSE


S322Scenario selfDefence := S322Scenario {
    voluntarilyCausesHurt := TRUE,
    intendsOrKnowsGrievous := TRUE,
    actuallyGrievous := TRUE,
    grievousKindIntended := "fracture_or_dislocation_of_a_bone",
    grievousKindCaused := "fracture_or_dislocation_of_a_bone",
    defenceApplies := TRUE,
}
assert is_s322_voluntarily_causing_grievous_hurt(
    selfDefence.voluntarilyCausesHurt && selfDefence.intendsOrKnowsGrievous && selfDefence.actuallyGrievous,
    selfDefence.defenceApplies
) == FALSE
