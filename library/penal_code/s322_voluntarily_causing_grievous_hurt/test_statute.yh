// Test file for s322
// Yuho v5 Syntax

referencing penal_code/s322_voluntarily_causing_grievous_hurt

struct S322CaseTest {
    bool criteriaMet,
}

S322CaseTest matches := S322CaseTest {
    criteriaMet := TRUE,
}

assert s322_matches(matches.criteriaMet) == TRUE

S322CaseTest nomatch := S322CaseTest {
    criteriaMet := FALSE,
}

assert s322_matches(nomatch.criteriaMet) == FALSE
