// Test file for s194_giving_fabricating_false_evidence_intent
// Yuho v5 Syntax

referencing penal_code/s194_giving_fabricating_false_evidence_intent

struct S194TestCase {
    bool givesOrFabricatesFalseEvidence,
    bool intendsCapitalConviction,
    bool innocentPersonConvictedAndExecuted,
}

S194TestCase executedInnocent := S194TestCase {
    givesOrFabricatesFalseEvidence := TRUE,
    intendsCapitalConviction := TRUE,
    innocentPersonConvictedAndExecuted := TRUE,
}

assert evaluate_s194(executedInnocent.givesOrFabricatesFalseEvidence, executedInnocent.intendsCapitalConviction, executedInnocent.innocentPersonConvictedAndExecuted) == "Liable under s194 - aggravated (death or life)"

S194TestCase baseOffence := S194TestCase {
    givesOrFabricatesFalseEvidence := TRUE,
    intendsCapitalConviction := TRUE,
    innocentPersonConvictedAndExecuted := FALSE,
}

assert evaluate_s194(baseOffence.givesOrFabricatesFalseEvidence, baseOffence.intendsCapitalConviction, baseOffence.innocentPersonConvictedAndExecuted) == "Liable under s194 - base (life or up to 20 years)"

S194TestCase noIntent := S194TestCase {
    givesOrFabricatesFalseEvidence := TRUE,
    intendsCapitalConviction := FALSE,
    innocentPersonConvictedAndExecuted := FALSE,
}

assert evaluate_s194(noIntent.givesOrFabricatesFalseEvidence, noIntent.intendsCapitalConviction, noIntent.innocentPersonConvictedAndExecuted) == "Not liable - no capital conviction intent"
