// Test file for s280
// Yuho v5 Syntax

referencing penal_code/s280_rash_navigation_vessel

struct RashNavTestCase { bool navigated, bool rash, bool endanger, }
RashNavTestCase good := RashNavTestCase { navigated := TRUE, rash := TRUE, endanger := TRUE, }
assert is_offence(good.navigated, good.rash, good.endanger) == TRUE
RashNavTestCase safeNav := RashNavTestCase { navigated := TRUE, rash := FALSE, endanger := FALSE, }
assert is_offence(safeNav.navigated, safeNav.rash, safeNav.endanger) == FALSE
