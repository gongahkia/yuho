// Test file for s203_giving_false_information_respecting_offence
// Yuho v5 Syntax

referencing penal_code/s203_giving_false_information_respecting_offence

struct S203TestCase {
    bool knowsOrReasonToBelieveOffenceCommitted,
    bool givesInformation,
    bool knowsOrBelievesInformationFalse,
}

S203TestCase misleadingPolice := S203TestCase {
    knowsOrReasonToBelieveOffenceCommitted := TRUE,
    givesInformation := TRUE,
    knowsOrBelievesInformationFalse := TRUE,
}

assert evaluate_s203(misleadingPolice.knowsOrReasonToBelieveOffenceCommitted, misleadingPolice.givesInformation, misleadingPolice.knowsOrBelievesInformationFalse) == "Liable under s203"

S203TestCase honestStatement := S203TestCase {
    knowsOrReasonToBelieveOffenceCommitted := TRUE,
    givesInformation := TRUE,
    knowsOrBelievesInformationFalse := FALSE,
}

assert evaluate_s203(honestStatement.knowsOrReasonToBelieveOffenceCommitted, honestStatement.givesInformation, honestStatement.knowsOrBelievesInformationFalse) == "Not liable - no knowledge of falsity"
