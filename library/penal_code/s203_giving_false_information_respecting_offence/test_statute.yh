// Test file for s203_giving_false_information_respecting_offence

referencing penal_code/s203_giving_false_information_respecting_offence

struct GivingFalseInformationRespectingTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

GivingFalseInformationRespectingTestCase guilty := GivingFalseInformationRespectingTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_giving_false_information_respecting(guilty.elements_satisfied, guilty.defence_applies) == TRUE

GivingFalseInformationRespectingTestCase defended := GivingFalseInformationRespectingTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_giving_false_information_respecting(defended.elements_satisfied, defended.defence_applies) == FALSE

GivingFalseInformationRespectingTestCase notMadeOut := GivingFalseInformationRespectingTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_giving_false_information_respecting(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
