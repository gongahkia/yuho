// Test file for s403_dishonest_misappropriation
// Yuho v5 Syntax

referencing penal_code/s403_dishonest_misappropriation

// ----- test structs -----

struct MisappropriationTestCase {
    string accused,
    string propertyOwner,
    string propertyType,
    bool propertyMovable,
    bool dishonestIntent,
    bool conversionToOwnUse,
}

// ----- all elements present: convicted -----

MisappropriationTestCase normalCase := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "ring",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert normalCase.accused == "A"
assert normalCase.propertyOwner == "B"
assert normalCase.propertyType == "ring"
assert normalCase.propertyMovable == TRUE
assert normalCase.dishonestIntent == TRUE
assert normalCase.conversionToOwnUse == TRUE
assert is_misappropriation(normalCase.propertyMovable, normalCase.dishonestIntent, normalCase.conversionToOwnUse) == TRUE

// ----- illustration example2: ring found near B's house, sold without finding owner -----

MisappropriationTestCase illustrationGuilty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "ring",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert is_misappropriation(illustrationGuilty.propertyMovable, illustrationGuilty.dishonestIntent, illustrationGuilty.conversionToOwnUse) == TRUE

// ----- illustration example1: no dishonest intent, not guilty -----

MisappropriationTestCase illustrationNotGuilty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "government",
    propertyType := "promissory_note",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := TRUE,
}

assert illustrationNotGuilty.dishonestIntent == FALSE
assert is_misappropriation(illustrationNotGuilty.propertyMovable, illustrationNotGuilty.dishonestIntent, illustrationNotGuilty.conversionToOwnUse) == FALSE

// ----- property not movable: not misappropriation -----

MisappropriationTestCase immovableProperty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "land",
    propertyMovable := FALSE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert immovableProperty.propertyMovable == FALSE
assert is_misappropriation(immovableProperty.propertyMovable, immovableProperty.dishonestIntent, immovableProperty.conversionToOwnUse) == FALSE

// ----- no dishonest intent: not misappropriation -----

MisappropriationTestCase noDishonesty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "wallet",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := TRUE,
}

assert noDishonesty.dishonestIntent == FALSE
assert is_misappropriation(noDishonesty.propertyMovable, noDishonesty.dishonestIntent, noDishonesty.conversionToOwnUse) == FALSE

// ----- no conversion to own use: not misappropriation -----

MisappropriationTestCase noConversion := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "phone",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := FALSE,
}

assert noConversion.conversionToOwnUse == FALSE
assert is_misappropriation(noConversion.propertyMovable, noConversion.dishonestIntent, noConversion.conversionToOwnUse) == FALSE

// ----- no elements present: not misappropriation -----

MisappropriationTestCase noElements := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "land",
    propertyMovable := FALSE,
    dishonestIntent := FALSE,
    conversionToOwnUse := FALSE,
}

assert noElements.propertyMovable == FALSE
assert noElements.dishonestIntent == FALSE
assert noElements.conversionToOwnUse == FALSE
assert is_misappropriation(noElements.propertyMovable, noElements.dishonestIntent, noElements.conversionToOwnUse) == FALSE

// ----- only movable property, missing mens rea and actus reus -----

MisappropriationTestCase onlyMovable := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "bicycle",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := FALSE,
}

assert onlyMovable.propertyMovable == TRUE
assert onlyMovable.dishonestIntent == FALSE
assert onlyMovable.conversionToOwnUse == FALSE
assert is_misappropriation(onlyMovable.propertyMovable, onlyMovable.dishonestIntent, onlyMovable.conversionToOwnUse) == FALSE

// ----- movable and dishonest but no conversion -----

MisappropriationTestCase noConversionOnly := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "cash",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := FALSE,
}

assert is_misappropriation(noConversionOnly.propertyMovable, noConversionOnly.dishonestIntent, noConversionOnly.conversionToOwnUse) == FALSE

// ----- movable and conversion but no dishonesty -----

MisappropriationTestCase noDishonestyOnly := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "laptop",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := TRUE,
}

assert is_misappropriation(noDishonestyOnly.propertyMovable, noDishonestyOnly.dishonestIntent, noDishonestyOnly.conversionToOwnUse) == FALSE

// ----- penalty verification -----

assert 403.penalty.imprisonment.min == 0 days
assert 403.penalty.imprisonment.max == 2 years
assert 403.penalty.fine.min == $0.00
assert 403.penalty.fine.max == $10,000.00
