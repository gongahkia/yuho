assert noElements.propertyMovable == FALSE
assert noElements.dishonestIntent == FALSE
assert noElements.conversionToOwnUse == FALSE
assert is_misappropriation(noElements.propertyMovable, noElements.dishonestIntent, noElements.conversionToOwnUse) == FALSE


MisappropriationTestCase onlyMovable := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "bicycle",
