// Test file for s403_dishonest_misappropriation

referencing penal_code/s403_dishonest_misappropriation


struct MisappropriationTestCase {
    string accused,
    string propertyOwner,
    string propertyType,
    bool propertyMovable,
    bool dishonestIntent,
    bool conversionToOwnUse,
}


MisappropriationTestCase normalCase := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "ring",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert normalCase.accused == "A"
assert normalCase.propertyOwner == "B"
assert normalCase.propertyType == "ring"
assert normalCase.propertyMovable == TRUE
assert normalCase.dishonestIntent == TRUE
assert normalCase.conversionToOwnUse == TRUE
assert is_misappropriation(normalCase.propertyMovable, normalCase.dishonestIntent, normalCase.conversionToOwnUse) == TRUE


MisappropriationTestCase illustrationGuilty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "ring",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert is_misappropriation(illustrationGuilty.propertyMovable, illustrationGuilty.dishonestIntent, illustrationGuilty.conversionToOwnUse) == TRUE


MisappropriationTestCase illustrationNotGuilty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "government",
    propertyType := "promissory_note",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := TRUE,
}

assert illustrationNotGuilty.dishonestIntent == FALSE
assert is_misappropriation(illustrationNotGuilty.propertyMovable, illustrationNotGuilty.dishonestIntent, illustrationNotGuilty.conversionToOwnUse) == FALSE


MisappropriationTestCase immovableProperty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "land",
    propertyMovable := FALSE,
    dishonestIntent := TRUE,
    conversionToOwnUse := TRUE,
}

assert immovableProperty.propertyMovable == FALSE
assert is_misappropriation(immovableProperty.propertyMovable, immovableProperty.dishonestIntent, immovableProperty.conversionToOwnUse) == FALSE


MisappropriationTestCase noDishonesty := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "wallet",
    propertyMovable := TRUE,
    dishonestIntent := FALSE,
    conversionToOwnUse := TRUE,
}

assert noDishonesty.dishonestIntent == FALSE
assert is_misappropriation(noDishonesty.propertyMovable, noDishonesty.dishonestIntent, noDishonesty.conversionToOwnUse) == FALSE


MisappropriationTestCase noConversion := MisappropriationTestCase {
    accused := "A",
    propertyOwner := "B",
    propertyType := "phone",
    propertyMovable := TRUE,
    dishonestIntent := TRUE,
    conversionToOwnUse := FALSE,
}

assert noConversion.conversionToOwnUse == FALSE
assert is_misappropriation(noConversion.propertyMovable, noConversion.dishonestIntent, noConversion.conversionToOwnUse) == FALSE


