// Test file for s106_when_such_right_extends_causing_harm_other
// Yuho v5 Syntax

referencing penal_code/s106_when_such_right_extends_causing_harm_other

struct NonFatalDefenceTestCase {
    string offenceType,
    bool withinRestrictions,
}

NonFatalDefenceTestCase theftCase := NonFatalDefenceTestCase {
    offenceType := "theft",
    withinRestrictions := TRUE,
}

assert extends_to_non_fatal_harm(theftCase.offenceType, theftCase.withinRestrictions) == TRUE

NonFatalDefenceTestCase outsideScope := NonFatalDefenceTestCase {
    offenceType := "robbery",
    withinRestrictions := TRUE,
}

assert extends_to_non_fatal_harm(outsideScope.offenceType, outsideScope.withinRestrictions) == FALSE
