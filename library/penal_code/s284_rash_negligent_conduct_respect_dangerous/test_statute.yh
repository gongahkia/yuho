// Test file for s284_rash_negligent_conduct_respect_dangerous
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s284_rash_negligent_conduct_respect_dangerous

struct RashNegligentConductRespectTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
RashNegligentConductRespectTestCase guilty := RashNegligentConductRespectTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_rash_negligent_conduct_respect(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
RashNegligentConductRespectTestCase defended := RashNegligentConductRespectTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_rash_negligent_conduct_respect(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
RashNegligentConductRespectTestCase notMadeOut := RashNegligentConductRespectTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_rash_negligent_conduct_respect(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
