// Test file for s467_forgery_valuable_security_will
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s467_forgery_valuable_security_will

struct ForgeryValuableSecurityWillTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
ForgeryValuableSecurityWillTestCase guilty := ForgeryValuableSecurityWillTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_forgery_valuable_security_will(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
ForgeryValuableSecurityWillTestCase defended := ForgeryValuableSecurityWillTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_forgery_valuable_security_will(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
ForgeryValuableSecurityWillTestCase notMadeOut := ForgeryValuableSecurityWillTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_forgery_valuable_security_will(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
