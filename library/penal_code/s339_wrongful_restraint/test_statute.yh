// Test file for s339_wrongful_restraint
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s339_wrongful_restraint

struct WrongfulRestraintTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
WrongfulRestraintTestCase guilty := WrongfulRestraintTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_wrongful_restraint(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
WrongfulRestraintTestCase defended := WrongfulRestraintTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_wrongful_restraint(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
WrongfulRestraintTestCase notMadeOut := WrongfulRestraintTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_wrongful_restraint(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
