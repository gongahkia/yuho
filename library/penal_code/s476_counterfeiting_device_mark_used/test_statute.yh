// Test file for s476_counterfeiting_device_mark_used
// Yuho v5 Syntax

referencing penal_code/s476_counterfeiting_device_mark_used

struct CounterfeitMarkOtherCaseTest {
    bool elementsSatisfied,
}

CounterfeitMarkOtherCaseTest positive := CounterfeitMarkOtherCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

CounterfeitMarkOtherCaseTest negative := CounterfeitMarkOtherCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
