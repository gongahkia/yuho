// Test file for s489C_possession_forged_counterfeit_currency_bank

referencing penal_code/s489C_possession_forged_counterfeit_currency_bank

struct PossessionForgedCounterfeitCurrencyTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

PossessionForgedCounterfeitCurrencyTestCase guilty := PossessionForgedCounterfeitCurrencyTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_possession_forged_counterfeit_currency(guilty.elements_satisfied, guilty.defence_applies) == TRUE

PossessionForgedCounterfeitCurrencyTestCase defended := PossessionForgedCounterfeitCurrencyTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_possession_forged_counterfeit_currency(defended.elements_satisfied, defended.defence_applies) == FALSE

PossessionForgedCounterfeitCurrencyTestCase notMadeOut := PossessionForgedCounterfeitCurrencyTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_possession_forged_counterfeit_currency(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
