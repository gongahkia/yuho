// Test file for s489C_possession_forged_counterfeit_currency_bank
// Yuho v5 Syntax

referencing penal_code/s489C_possession_forged_counterfeit_currency_bank

struct PossessionForgedCurrencyCaseTest {
    bool elementsSatisfied,
}

PossessionForgedCurrencyCaseTest positive := PossessionForgedCurrencyCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

PossessionForgedCurrencyCaseTest negative := PossessionForgedCurrencyCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
