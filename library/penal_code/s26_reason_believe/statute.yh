/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr26-#pr26-

statute 26 "“Reason to believe”" effective 1872-01-01 {
    definitions {
        reason_to_believe := "A person is said to have “reason to believe” a thing, if he has sufficient cause to believe that thing, but not otherwise.";
    }
}
