// Test file for s285_causing_contributing_risk_dangerous_fire

referencing penal_code/s285_causing_contributing_risk_dangerous_fire

struct CausingContributingRiskDangerousTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CausingContributingRiskDangerousTestCase guilty := CausingContributingRiskDangerousTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_causing_contributing_risk_dangerous(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CausingContributingRiskDangerousTestCase defended := CausingContributingRiskDangerousTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_causing_contributing_risk_dangerous(defended.elements_satisfied, defended.defence_applies) == FALSE

CausingContributingRiskDangerousTestCase notMadeOut := CausingContributingRiskDangerousTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_causing_contributing_risk_dangerous(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
