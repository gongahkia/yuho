// Test file for s130D_genocide

referencing penal_code/s130D_genocide

struct GenocideTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

GenocideTestCase guilty := GenocideTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_genocide(guilty.elements_satisfied, guilty.defence_applies) == TRUE

GenocideTestCase defended := GenocideTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_genocide(defended.elements_satisfied, defended.defence_applies) == FALSE

GenocideTestCase notMadeOut := GenocideTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_genocide(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
