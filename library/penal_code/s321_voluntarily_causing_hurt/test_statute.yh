// Test file for s321_voluntarily_causing_hurt

referencing penal_code/s321_voluntarily_causing_hurt


struct S321TestCase {
    bool intentToCauseHurt,
    bool knowledgeLikelyToCauseHurt,
    bool hurtCaused,
}


S321TestCase intentHurt := S321TestCase {
    intentToCauseHurt := TRUE,
    knowledgeLikelyToCauseHurt := FALSE,
    hurtCaused := TRUE,
}

assert is_voluntary_hurt(intentHurt.intentToCauseHurt, intentHurt.knowledgeLikelyToCauseHurt, intentHurt.hurtCaused) == TRUE


S321TestCase knowledgeHurt := S321TestCase {
    intentToCauseHurt := FALSE,
    knowledgeLikelyToCauseHurt := TRUE,
    hurtCaused := TRUE,
}

assert is_voluntary_hurt(knowledgeHurt.intentToCauseHurt, knowledgeHurt.knowledgeLikelyToCauseHurt, knowledgeHurt.hurtCaused) == TRUE


S321TestCase noHurt := S321TestCase {
    intentToCauseHurt := TRUE,
    knowledgeLikelyToCauseHurt := TRUE,
    hurtCaused := FALSE,
}

assert is_voluntary_hurt(noHurt.intentToCauseHurt, noHurt.knowledgeLikelyToCauseHurt, noHurt.hurtCaused) == FALSE


S321TestCase noMensRea := S321TestCase {
    intentToCauseHurt := FALSE,
    knowledgeLikelyToCauseHurt := FALSE,
    hurtCaused := TRUE,
}

assert is_voluntary_hurt(noMensRea.intentToCauseHurt, noMensRea.knowledgeLikelyToCauseHurt, noMensRea.hurtCaused) == FALSE
