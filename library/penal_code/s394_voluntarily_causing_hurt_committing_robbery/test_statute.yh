// Test file for s394_voluntarily_causing_hurt_committing_robbery

referencing penal_code/s394_voluntarily_causing_hurt_committing_robbery

struct RobberyWithHurtTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

RobberyWithHurtTestCase guilty := RobberyWithHurtTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_robbery_with_hurt(guilty.elements_satisfied, guilty.defence_applies) == TRUE

RobberyWithHurtTestCase defended := RobberyWithHurtTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_robbery_with_hurt(defended.elements_satisfied, defended.defence_applies) == FALSE

RobberyWithHurtTestCase notMadeOut := RobberyWithHurtTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_robbery_with_hurt(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
