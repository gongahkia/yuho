// Test file for s328_causing_hurt_means_poison_etc_intent_commit

referencing penal_code/s328_causing_hurt_means_poison_etc_intent_commit

struct CausingHurtMeansPoisonTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CausingHurtMeansPoisonTestCase guilty := CausingHurtMeansPoisonTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_causing_hurt_means_poison(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CausingHurtMeansPoisonTestCase defended := CausingHurtMeansPoisonTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_causing_hurt_means_poison(defended.elements_satisfied, defended.defence_applies) == FALSE

CausingHurtMeansPoisonTestCase notMadeOut := CausingHurtMeansPoisonTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_causing_hurt_means_poison(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
