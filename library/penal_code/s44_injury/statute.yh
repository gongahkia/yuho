/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr44-#pr44-

statute 44 "“Injury”" effective 1872-01-01 {
    definitions {
        injury := "Any harm whatever illegally caused to any person, in body, mind, reputation or property.";
    }
}
