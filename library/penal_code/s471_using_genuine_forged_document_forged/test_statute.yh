// Test file for s471_using_genuine_forged_document_forged
// Yuho v5 Syntax

referencing penal_code/s471_using_genuine_forged_document_forged

struct UsingForgedDocumentCaseTest {
    bool elementsSatisfied,
}

UsingForgedDocumentCaseTest positive := UsingForgedDocumentCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

UsingForgedDocumentCaseTest negative := UsingForgedDocumentCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
