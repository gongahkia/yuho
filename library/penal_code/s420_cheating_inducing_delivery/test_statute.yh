// Test file for s420_cheating_inducing_delivery
// Yuho v5 Syntax

referencing penal_code/s420_cheating_inducing_delivery

// ----- test structs -----

struct CheatingDeliveryTestCase {
    bool cheatingCommitted,
    bool deliveryInduced,
    string propertyType,
}

// ----- normal s420 offence: cheating + delivery -----

CheatingDeliveryTestCase normalS420 := CheatingDeliveryTestCase {
    cheatingCommitted := TRUE,
    deliveryInduced := TRUE,
    propertyType := "movable_property",
}

assert normalS420.cheatingCommitted == TRUE
assert normalS420.deliveryInduced == TRUE
assert normalS420.propertyType == "movable_property"
assert is_s420_cheating(normalS420.cheatingCommitted, normalS420.deliveryInduced) == TRUE

// ----- valuable security delivery -----

CheatingDeliveryTestCase valuableSecurityCase := CheatingDeliveryTestCase {
    cheatingCommitted := TRUE,
    deliveryInduced := TRUE,
    propertyType := "valuable_security",
}

assert valuableSecurityCase.propertyType == "valuable_security"
assert is_s420_cheating(valuableSecurityCase.cheatingCommitted, valuableSecurityCase.deliveryInduced) == TRUE

// ----- no cheating committed: not s420 -----

CheatingDeliveryTestCase noCheating := CheatingDeliveryTestCase {
    cheatingCommitted := FALSE,
    deliveryInduced := TRUE,
    propertyType := "movable_property",
}

assert noCheating.cheatingCommitted == FALSE
assert is_s420_cheating(noCheating.cheatingCommitted, noCheating.deliveryInduced) == FALSE

// ----- no delivery induced: not s420 -----

CheatingDeliveryTestCase noDelivery := CheatingDeliveryTestCase {
    cheatingCommitted := TRUE,
    deliveryInduced := FALSE,
    propertyType := "movable_property",
}

assert noDelivery.deliveryInduced == FALSE
assert is_s420_cheating(noDelivery.cheatingCommitted, noDelivery.deliveryInduced) == FALSE

// ----- neither cheating nor delivery: not s420 -----

CheatingDeliveryTestCase neitherCase := CheatingDeliveryTestCase {
    cheatingCommitted := FALSE,
    deliveryInduced := FALSE,
    propertyType := "none",
}

assert neitherCase.cheatingCommitted == FALSE
assert neitherCase.deliveryInduced == FALSE
assert is_s420_cheating(neitherCase.cheatingCommitted, neitherCase.deliveryInduced) == FALSE
