// Test file for s465_punishment_for_forgery

referencing penal_code/s465_punishment_for_forgery


struct S465TestCase {
    bool forgeryCommitted,
}


S465TestCase guilty := S465TestCase {
    forgeryCommitted := TRUE,
}

assert guilty.forgeryCommitted == TRUE
assert s465_applies(guilty.forgeryCommitted) == TRUE


S465TestCase notGuilty := S465TestCase {
    forgeryCommitted := FALSE,
}

assert notGuilty.forgeryCommitted == FALSE
assert s465_applies(notGuilty.forgeryCommitted) == FALSE
