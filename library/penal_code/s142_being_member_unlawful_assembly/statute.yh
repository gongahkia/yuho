/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr142-#pr142-

statute 142 "Being a member of an unlawful assembly" effective 1872-01-01 {
    definitions {
        member_of_an_unlawful_assembly := "Whoever, being aware of facts which render any assembly an unlawful assembly, intentionally joins that assembly, or continues in it";
    }
}
