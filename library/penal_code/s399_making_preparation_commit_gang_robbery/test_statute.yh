// Test file for s399_making_preparation_commit_gang_robbery
// Yuho v5 Syntax

referencing penal_code/s399_making_preparation_commit_gang_robbery

struct S399TestCase {
    bool preparationForGangRobbery,
}

S399TestCase prepared := S399TestCase {
    preparationForGangRobbery := TRUE,
}

assert s399_applies(prepared.preparationForGangRobbery) == TRUE

S399TestCase idle := S399TestCase {
    preparationForGangRobbery := FALSE,
}

assert s399_applies(idle.preparationForGangRobbery) == FALSE
