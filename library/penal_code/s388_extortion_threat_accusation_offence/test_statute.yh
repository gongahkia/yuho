// Test file for s388_extortion_threat_accusation_offence
// Yuho v5 Syntax

referencing penal_code/s388_extortion_threat_accusation_offence

struct S388TestCase {
    bool extortionCommitted,
    bool fearOfSeriousAccusation,
}

S388TestCase blackmail := S388TestCase {
    extortionCommitted := TRUE,
    fearOfSeriousAccusation := TRUE,
}

assert s388_applies(blackmail.extortionCommitted, blackmail.fearOfSeriousAccusation) == TRUE

S388TestCase notSerious := S388TestCase {
    extortionCommitted := TRUE,
    fearOfSeriousAccusation := FALSE,
}

assert s388_applies(notSerious.extortionCommitted, notSerious.fearOfSeriousAccusation) == FALSE
