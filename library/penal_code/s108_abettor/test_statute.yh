/// @meta source=test_statute_for_s108
referencing penal_code/s108_abettor

struct S108TestCase {
    bool elements_satisfied,
    bool defence_applies,
}

S108TestCase guilty := S108TestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_s108_abettor(guilty.elements_satisfied, guilty.defence_applies) == TRUE

S108TestCase defended := S108TestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_s108_abettor(defended.elements_satisfied, defended.defence_applies) == FALSE

S108TestCase notMadeOut := S108TestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_s108_abettor(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
