// Test file for s108_abettor
// Yuho v5 Syntax

referencing penal_code/s108_abettor

struct AbettorTestCase {
    bool offenceOrActWhichWouldBeOffence,
    bool abettorHasSameIntentionOrKnowledge,
}

AbettorTestCase qualifying := AbettorTestCase {
    offenceOrActWhichWouldBeOffence := TRUE,
    abettorHasSameIntentionOrKnowledge := TRUE,
}
assert is_abettor(qualifying.offenceOrActWhichWouldBeOffence, qualifying.abettorHasSameIntentionOrKnowledge) == TRUE

AbettorTestCase noIntent := AbettorTestCase {
    offenceOrActWhichWouldBeOffence := TRUE,
    abettorHasSameIntentionOrKnowledge := FALSE,
}
assert is_abettor(noIntent.offenceOrActWhichWouldBeOffence, noIntent.abettorHasSameIntentionOrKnowledge) == FALSE
