// Test file for s123
// Yuho v5 Syntax

referencing penal_code/s123_concealing_intent_facilitate_design_wage_war

struct S123Test {
    bool concealsDesignToWageWar,
    bool intendsToFacilitateOrKnowsConcealmentWillFacilitate,
}

S123Test qualifying := S123Test {
    concealsDesignToWageWar := TRUE,
    intendsToFacilitateOrKnowsConcealmentWillFacilitate := TRUE,
}
assert s123_applies(qualifying.concealsDesignToWageWar, qualifying.intendsToFacilitateOrKnowsConcealmentWillFacilitate) == TRUE

S123Test noIntent := S123Test {
    concealsDesignToWageWar := TRUE,
    intendsToFacilitateOrKnowsConcealmentWillFacilitate := FALSE,
}
assert s123_applies(noIntent.concealsDesignToWageWar, noIntent.intendsToFacilitateOrKnowsConcealmentWillFacilitate) == FALSE
