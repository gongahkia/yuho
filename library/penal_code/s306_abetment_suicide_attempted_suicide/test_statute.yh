// Test file for s306
// Yuho v5 Syntax

referencing penal_code/s306_abetment_suicide_attempted_suicide

struct S306CaseTestCase {
    bool suicideOrAttempt,
    bool abetment,
}

S306CaseTestCase matching := S306CaseTestCase {
    suicideOrAttempt := TRUE,
    abetment := TRUE,
}

assert applies_s306(matching.suicideOrAttempt, matching.abetment) == TRUE

S306CaseTestCase missing := S306CaseTestCase {
    suicideOrAttempt := FALSE,
    abetment := TRUE,
}

assert applies_s306(missing.suicideOrAttempt, missing.abetment) == FALSE
