// Test file for s306_abetment_suicide_attempted_suicide
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s306_abetment_suicide_attempted_suicide

struct AbetmentSuicideAttemptedSuicideTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
AbetmentSuicideAttemptedSuicideTestCase guilty := AbetmentSuicideAttemptedSuicideTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_abetment_suicide_attempted_suicide(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
AbetmentSuicideAttemptedSuicideTestCase defended := AbetmentSuicideAttemptedSuicideTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_abetment_suicide_attempted_suicide(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
AbetmentSuicideAttemptedSuicideTestCase notMadeOut := AbetmentSuicideAttemptedSuicideTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_abetment_suicide_attempted_suicide(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
