// Test file for s199_false_statement_made_declaration_which_law
// Yuho v5 Syntax

referencing penal_code/s199_false_statement_made_declaration_which_law

struct S199TestCase {
    bool makesDeclaration,
    bool declarationReceivableAsEvidence,
    bool statementFalse,
    bool touchingMaterialPoint,
    bool knowsOrBelievesFalse,
}

S199TestCase lyingOnAffidavit := S199TestCase {
    makesDeclaration := TRUE,
    declarationReceivableAsEvidence := TRUE,
    statementFalse := TRUE,
    touchingMaterialPoint := TRUE,
    knowsOrBelievesFalse := TRUE,
}

assert evaluate_s199(lyingOnAffidavit.makesDeclaration, lyingOnAffidavit.declarationReceivableAsEvidence, lyingOnAffidavit.statementFalse, lyingOnAffidavit.touchingMaterialPoint, lyingOnAffidavit.knowsOrBelievesFalse) == "Liable under s199"

S199TestCase immaterialLie := S199TestCase {
    makesDeclaration := TRUE,
    declarationReceivableAsEvidence := TRUE,
    statementFalse := TRUE,
    touchingMaterialPoint := FALSE,
    knowsOrBelievesFalse := TRUE,
}

assert evaluate_s199(immaterialLie.makesDeclaration, immaterialLie.declarationReceivableAsEvidence, immaterialLie.statementFalse, immaterialLie.touchingMaterialPoint, immaterialLie.knowsOrBelievesFalse) == "Not liable - not touching material point"
