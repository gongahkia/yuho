/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr363A-#pr363A-
/// @section 363A
// Singapore Penal Code Section 363A

statute 363.1 "Punishment for abduction" effective 1872-01-01 {
    definitions {
        abduction_reference := "Abduction as defined under section 362";
    }

    penalty {
        imprisonment := 0 years .. 7 years;
        fine := $0.00 .. $10,000.00;
    }

}
