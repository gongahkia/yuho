// Test file for s272
// Yuho v5 Syntax

referencing penal_code/s272_adulteration_food_drink_which_intended_sale

struct AdulterationFoodTestCase { bool adulterated, bool noxious, bool intentOrKnowledge, }
AdulterationFoodTestCase good := AdulterationFoodTestCase { adulterated := TRUE, noxious := TRUE, intentOrKnowledge := TRUE, }
assert is_offence(good.adulterated, good.noxious, good.intentOrKnowledge) == TRUE
AdulterationFoodTestCase noIntent := AdulterationFoodTestCase { adulterated := TRUE, noxious := TRUE, intentOrKnowledge := FALSE, }
assert is_offence(noIntent.adulterated, noIntent.noxious, noIntent.intentOrKnowledge) == FALSE
