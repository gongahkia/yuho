// Test file for s489B_using_genuine_forged_counterfeit_currency
// Yuho v5 Syntax

referencing penal_code/s489B_using_genuine_forged_counterfeit_currency

struct UsingForgedCurrencyCaseTest {
    bool elementsSatisfied,
}

UsingForgedCurrencyCaseTest positive := UsingForgedCurrencyCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

UsingForgedCurrencyCaseTest negative := UsingForgedCurrencyCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
