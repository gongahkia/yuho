// Singapore Penal Code Section 29B
// Yuho v5 Syntax

statute 29B "“Electronic record”" effective 1872-01-01 {
    definitions {
        electronic_record := "The expression “electronic record” has the same meaning as in the Electronic Transactions Act 2010.";
    }
}
