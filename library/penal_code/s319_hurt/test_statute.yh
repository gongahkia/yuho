// Test file for s319_hurt

referencing penal_code/s319_hurt


struct HurtTestCase {
    string physicalElement,
    bool causedToVictim,
}


HurtTestCase bodilyPainCase := HurtTestCase {
    physicalElement := "bodily_pain",
    causedToVictim := TRUE,
}

assert bodilyPainCase.physicalElement == "bodily_pain"
assert bodilyPainCase.causedToVictim == TRUE
assert is_hurt(bodilyPainCase.physicalElement, bodilyPainCase.causedToVictim) == TRUE


HurtTestCase diseaseCase := HurtTestCase {
    physicalElement := "disease",
    causedToVictim := TRUE,
}

assert diseaseCase.physicalElement == "disease"
assert is_hurt(diseaseCase.physicalElement, diseaseCase.causedToVictim) == TRUE


HurtTestCase infirmityCase := HurtTestCase {
    physicalElement := "infirmity",
    causedToVictim := TRUE,
}

assert infirmityCase.physicalElement == "infirmity"
assert is_hurt(infirmityCase.physicalElement, infirmityCase.causedToVictim) == TRUE


HurtTestCase unconsciousnessCase := HurtTestCase {
    physicalElement := "unconsciousness",
    causedToVictim := TRUE,
}

assert unconsciousnessCase.physicalElement == "unconsciousness"
assert is_hurt(unconsciousnessCase.physicalElement, unconsciousnessCase.causedToVictim) == TRUE


HurtTestCase noElement := HurtTestCase {
    physicalElement := "none",
    causedToVictim := TRUE,
}

assert noElement.physicalElement == "none"
assert is_hurt(noElement.physicalElement, noElement.causedToVictim) == FALSE


HurtTestCase notCaused := HurtTestCase {
    physicalElement := "bodily_pain",
    causedToVictim := FALSE,
}

assert notCaused.causedToVictim == FALSE
assert is_hurt(notCaused.physicalElement, notCaused.causedToVictim) == FALSE


HurtTestCase unknownElement := HurtTestCase {
    physicalElement := "emotional_distress",
    causedToVictim := TRUE,
}

assert unknownElement.physicalElement == "emotional_distress"
assert is_hurt(unknownElement.physicalElement, unknownElement.causedToVictim) == FALSE
