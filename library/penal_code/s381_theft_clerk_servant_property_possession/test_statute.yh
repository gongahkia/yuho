// Test file for s381_theft_clerk_servant_property_possession
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s381_theft_clerk_servant_property_possession

struct TheftClerkServantPropertyTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
TheftClerkServantPropertyTestCase guilty := TheftClerkServantPropertyTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_theft_clerk_servant_property(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
TheftClerkServantPropertyTestCase defended := TheftClerkServantPropertyTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_theft_clerk_servant_property(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
TheftClerkServantPropertyTestCase notMadeOut := TheftClerkServantPropertyTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_theft_clerk_servant_property(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
