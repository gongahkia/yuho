// Test file for s381_theft_clerk_servant_property_possession
// Yuho v5 Syntax

referencing penal_code/s381_theft_clerk_servant_property_possession

struct S381TestCase {
    bool theftCommitted,
    bool clerkOrServant,
    bool propertyInMastersPossession,
}

S381TestCase clerkTheft := S381TestCase {
    theftCommitted := TRUE,
    clerkOrServant := TRUE,
    propertyInMastersPossession := TRUE,
}

assert s381_applies(clerkTheft.theftCommitted, clerkTheft.clerkOrServant, clerkTheft.propertyInMastersPossession) == TRUE

S381TestCase notClerk := S381TestCase {
    theftCommitted := TRUE,
    clerkOrServant := FALSE,
    propertyInMastersPossession := TRUE,
}

assert s381_applies(notClerk.theftCommitted, notClerk.clerkOrServant, notClerk.propertyInMastersPossession) == FALSE
