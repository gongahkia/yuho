// Test file for s124
// Yuho v5 Syntax

referencing penal_code/s124_assaulting_president_etc_intent_compel

struct S124Test {
    string targetRole,
    bool intendsToInduceOrCompel,
    bool assaultsOrWrongfullyRestrainsOrOverawes,
}

S124Test presidentAssault := S124Test {
    targetRole := "president",
    intendsToInduceOrCompel := TRUE,
    assaultsOrWrongfullyRestrainsOrOverawes := TRUE,
}
assert s124_applies(presidentAssault.targetRole, presidentAssault.intendsToInduceOrCompel, presidentAssault.assaultsOrWrongfullyRestrainsOrOverawes) == TRUE

S124Test noIntent := S124Test {
    targetRole := "mp",
    intendsToInduceOrCompel := FALSE,
    assaultsOrWrongfullyRestrainsOrOverawes := TRUE,
}
assert s124_applies(noIntent.targetRole, noIntent.intendsToInduceOrCompel, noIntent.assaultsOrWrongfullyRestrainsOrOverawes) == FALSE
