// Test file for s124_assaulting_president_etc_intent_compel
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s124_assaulting_president_etc_intent_compel

struct AssaultingPresidentEtcIntentTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
AssaultingPresidentEtcIntentTestCase guilty := AssaultingPresidentEtcIntentTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_assaulting_president_etc_intent(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
AssaultingPresidentEtcIntentTestCase defended := AssaultingPresidentEtcIntentTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_assaulting_president_etc_intent(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
AssaultingPresidentEtcIntentTestCase notMadeOut := AssaultingPresidentEtcIntentTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_assaulting_president_etc_intent(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
