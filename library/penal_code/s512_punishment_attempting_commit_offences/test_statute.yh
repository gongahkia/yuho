// Test file for s512_punishment_attempting_commit_offences
// Yuho v5 Syntax

referencing penal_code/s512_punishment_attempting_commit_offences

struct AttemptPunishmentCaseTest {
    bool offenceCommitted,
}

AttemptPunishmentCaseTest convicted := AttemptPunishmentCaseTest {
    offenceCommitted := TRUE,
}

assert convicted.offenceCommitted == TRUE
assert punishment_applies(convicted.offenceCommitted) == TRUE

AttemptPunishmentCaseTest acquitted := AttemptPunishmentCaseTest {
    offenceCommitted := FALSE,
}

assert acquitted.offenceCommitted == FALSE
assert punishment_applies(acquitted.offenceCommitted) == FALSE
