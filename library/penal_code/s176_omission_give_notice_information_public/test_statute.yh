/// @meta source=test_statute_for_s176
referencing penal_code/s176_omission_give_notice_information_public

struct S176TestCase {
    bool elements_satisfied,
    bool defence_applies,
}

S176TestCase guilty := S176TestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_s176_omission_give_notice(guilty.elements_satisfied, guilty.defence_applies) == TRUE

S176TestCase defended := S176TestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_s176_omission_give_notice(defended.elements_satisfied, defended.defence_applies) == FALSE

S176TestCase notMadeOut := S176TestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_s176_omission_give_notice(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
