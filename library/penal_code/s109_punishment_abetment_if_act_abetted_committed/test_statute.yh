// Test file for s109_punishment_abetment_if_act_abetted_committed

referencing penal_code/s109_punishment_abetment_if_act_abetted_committed

struct PunishmentAbetmentIfActTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

PunishmentAbetmentIfActTestCase guilty := PunishmentAbetmentIfActTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_punishment_abetment_if_act(guilty.elements_satisfied, guilty.defence_applies) == TRUE

PunishmentAbetmentIfActTestCase defended := PunishmentAbetmentIfActTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_punishment_abetment_if_act(defended.elements_satisfied, defended.defence_applies) == FALSE

PunishmentAbetmentIfActTestCase notMadeOut := PunishmentAbetmentIfActTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_punishment_abetment_if_act(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
