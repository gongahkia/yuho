// Test file for s109
// Yuho v5 Syntax

referencing penal_code/s109_punishment_abetment_if_act_abetted_committed

struct S109Test {
    bool actAbettedCommittedInConsequence,
    bool expressProvisionExists,
}

S109Test qualifying := S109Test {
    actAbettedCommittedInConsequence := TRUE,
    expressProvisionExists := FALSE,
}
assert s109_applies(qualifying.actAbettedCommittedInConsequence, qualifying.expressProvisionExists) == TRUE

S109Test expressCarve := S109Test {
    actAbettedCommittedInConsequence := TRUE,
    expressProvisionExists := TRUE,
}
assert s109_applies(expressCarve.actAbettedCommittedInConsequence, expressCarve.expressProvisionExists) == FALSE
