// Test file for s198_using_true_certificate_one_known_false
// Yuho v5 Syntax

referencing penal_code/s198_using_true_certificate_one_known_false

struct S198TestCase {
    bool corruptlyUsesAsTrue,
    bool knowsCertificateFalseInMaterialPoint,
}

S198TestCase fakeCertUser := S198TestCase {
    corruptlyUsesAsTrue := TRUE,
    knowsCertificateFalseInMaterialPoint := TRUE,
}

assert evaluate_s198(fakeCertUser.corruptlyUsesAsTrue, fakeCertUser.knowsCertificateFalseInMaterialPoint) == "Liable under s198"

S198TestCase honestUser := S198TestCase {
    corruptlyUsesAsTrue := TRUE,
    knowsCertificateFalseInMaterialPoint := FALSE,
}

assert evaluate_s198(honestUser.corruptlyUsesAsTrue, honestUser.knowsCertificateFalseInMaterialPoint) == "Not liable - no knowledge of material falsity"
