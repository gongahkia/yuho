// Test file for s302_punishment_for_murder

referencing penal_code/s302_punishment_for_murder


struct MurderPunishmentTestCase {
    bool murderCommitted,
}


MurderPunishmentTestCase convicted := MurderPunishmentTestCase {
    murderCommitted := TRUE,
}

assert convicted.murderCommitted == TRUE
assert punishment_applies(convicted.murderCommitted) == TRUE


MurderPunishmentTestCase notConvicted := MurderPunishmentTestCase {
    murderCommitted := FALSE,
}

assert notConvicted.murderCommitted == FALSE
assert punishment_applies(notConvicted.murderCommitted) == FALSE
