// Test file for s287
// Yuho v5 Syntax

referencing penal_code/s287_rash_negligent_conduct_respect_machinery

struct S287CaseTestCase {
    bool machineryPossessionOrCare,
    bool rashOrNegligent,
    bool dangerOutcome,
}

S287CaseTestCase matching := S287CaseTestCase {
    machineryPossessionOrCare := TRUE,
    rashOrNegligent := TRUE,
    dangerOutcome := TRUE,
}

assert applies_s287(matching.machineryPossessionOrCare, matching.rashOrNegligent, matching.dangerOutcome) == TRUE

S287CaseTestCase missing := S287CaseTestCase {
    machineryPossessionOrCare := FALSE,
    rashOrNegligent := TRUE,
    dangerOutcome := TRUE,
}

assert applies_s287(missing.machineryPossessionOrCare, missing.rashOrNegligent, missing.dangerOutcome) == FALSE
