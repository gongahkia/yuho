// Test file for s407_criminal_breach_trust_property_entrusted
// Yuho v5 Syntax

referencing penal_code/s407_criminal_breach_trust_property_entrusted

struct S407TestCase {
    bool entrustedForTransportOrStorage,
    bool criminalBreachOfTrustCommitted,
}

S407TestCase carrierCase := S407TestCase {
    entrustedForTransportOrStorage := TRUE,
    criminalBreachOfTrustCommitted := TRUE,
}

assert s407_applies(carrierCase.entrustedForTransportOrStorage, carrierCase.criminalBreachOfTrustCommitted) == TRUE

S407TestCase casualEntrust := S407TestCase {
    entrustedForTransportOrStorage := FALSE,
    criminalBreachOfTrustCommitted := TRUE,
}

assert s407_applies(casualEntrust.entrustedForTransportOrStorage, casualEntrust.criminalBreachOfTrustCommitted) == FALSE
