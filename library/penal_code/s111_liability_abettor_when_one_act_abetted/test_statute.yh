// Test file for s111
// Yuho v5 Syntax

referencing penal_code/s111_liability_abettor_when_one_act_abetted

struct S111Test {
    bool oneActAbetted,
    bool differentActDone,
    bool differentActProbableConsequence,
}

S111Test probable := S111Test {
    oneActAbetted := TRUE,
    differentActDone := TRUE,
    differentActProbableConsequence := TRUE,
}
assert s111_liable(probable.oneActAbetted, probable.differentActDone, probable.differentActProbableConsequence) == TRUE

S111Test improbable := S111Test {
    oneActAbetted := TRUE,
    differentActDone := TRUE,
    differentActProbableConsequence := FALSE,
}
assert s111_liable(improbable.oneActAbetted, improbable.differentActDone, improbable.differentActProbableConsequence) == FALSE
