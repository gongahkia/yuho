// Test file for s489A_forging_counterfeiting_currency_bank_notes
// Yuho v5 Syntax

referencing penal_code/s489A_forging_counterfeiting_currency_bank_notes

struct ForgingCurrencyCaseTest {
    bool elementsSatisfied,
}

ForgingCurrencyCaseTest positive := ForgingCurrencyCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

ForgingCurrencyCaseTest negative := ForgingCurrencyCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
