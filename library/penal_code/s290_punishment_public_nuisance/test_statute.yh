// Test file for s290
// Yuho v5 Syntax

referencing penal_code/s290_punishment_public_nuisance

struct S290CaseTestCase {
    bool publicNuisance,
    bool notOtherwisePunishable,
}

S290CaseTestCase matching := S290CaseTestCase {
    publicNuisance := TRUE,
    notOtherwisePunishable := TRUE,
}

assert applies_s290(matching.publicNuisance, matching.notOtherwisePunishable) == TRUE

S290CaseTestCase missing := S290CaseTestCase {
    publicNuisance := FALSE,
    notOtherwisePunishable := TRUE,
}

assert applies_s290(missing.publicNuisance, missing.notOtherwisePunishable) == FALSE
