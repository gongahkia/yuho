/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr324-#pr324-
// Singapore Penal Code Section 324 -- Voluntarily causing hurt by dangerous weapons or means
// Yuho v5 Syntax

struct S324Case {
    string accused,
    string victim,
    bool actusReus,
    bool mensRea,
}

fn s324_applies(bool actusReus, bool mensRea) : bool {
    match {
        case TRUE if actusReus == TRUE && mensRea == TRUE := consequence TRUE;
        case _ := consequence FALSE;
    }
}

/// @amendment [15/2019]
statute 324 "Voluntarily causing hurt by dangerous weapons or means" effective 1872-01-01 {
    definitions {
        offence_summary := "Voluntarily causing hurt by dangerous weapons, fire, poison, corrosive, explosive, harmful substance or animal.";
    }

    elements {
        /// mental element required for the offence
        mens_rea intent := "Intent or knowledge as required by the section";
        /// physical act constituting the offence
        actus_reus act := "The prohibited act defined by the section";
        /// contextual requirement -- victim, circumstances, or result
        circumstance context := "Statutory circumstances are satisfied";
    }

    penalty {
        imprisonment := 0 years .. 7 years;
        fine := $0.00 .. $50,000.00;
        caning := 0 .. 24 strokes;
    }

    illustration example1 {
        "A commits the conduct described in section 324 against B. A is guilty of the offence under section 324."
    }
}
