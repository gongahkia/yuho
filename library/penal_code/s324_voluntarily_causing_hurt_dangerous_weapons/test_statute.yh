// Test file for s324
// Yuho v5 Syntax

referencing penal_code/s324_voluntarily_causing_hurt_dangerous_weapons

struct S324CaseTest {
    bool actusReus,
    bool mensRea,
}

S324CaseTest satisfied := S324CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s324_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S324CaseTest missingMens := S324CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s324_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
