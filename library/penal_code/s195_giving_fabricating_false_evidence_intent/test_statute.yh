// Test file for s195_giving_fabricating_false_evidence_intent
// Yuho v5 Syntax

referencing penal_code/s195_giving_fabricating_false_evidence_intent

struct S195TestCase {
    bool givesOrFabricatesFalseEvidence,
    bool intendsSevenYearPlusConviction,
    bool intendsLifeImprisonmentConviction,
}

S195TestCase framingForLife := S195TestCase {
    givesOrFabricatesFalseEvidence := TRUE,
    intendsSevenYearPlusConviction := FALSE,
    intendsLifeImprisonmentConviction := TRUE,
}

assert evaluate_s195(framingForLife.givesOrFabricatesFalseEvidence, framingForLife.intendsSevenYearPlusConviction, framingForLife.intendsLifeImprisonmentConviction) == "Liable under s195(2) - up to 20 years"

S195TestCase framingFor7Y := S195TestCase {
    givesOrFabricatesFalseEvidence := TRUE,
    intendsSevenYearPlusConviction := TRUE,
    intendsLifeImprisonmentConviction := FALSE,
}

assert evaluate_s195(framingFor7Y.givesOrFabricatesFalseEvidence, framingFor7Y.intendsSevenYearPlusConviction, framingFor7Y.intendsLifeImprisonmentConviction) == "Liable under s195(1) - as convicted would be punished"

S195TestCase noFalseEvidence := S195TestCase {
    givesOrFabricatesFalseEvidence := FALSE,
    intendsSevenYearPlusConviction := TRUE,
    intendsLifeImprisonmentConviction := FALSE,
}

assert evaluate_s195(noFalseEvidence.givesOrFabricatesFalseEvidence, noFalseEvidence.intendsSevenYearPlusConviction, noFalseEvidence.intendsLifeImprisonmentConviction) == "Not liable - no false evidence"
