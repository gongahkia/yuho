// Test file for s489E_abetting_singapore_counterfeiting_currency
// Yuho v5 Syntax

referencing penal_code/s489E_abetting_singapore_counterfeiting_currency

struct AbettingExtraterritorialCaseTest {
    bool elementsSatisfied,
}

AbettingExtraterritorialCaseTest positive := AbettingExtraterritorialCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

AbettingExtraterritorialCaseTest negative := AbettingExtraterritorialCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
