// Test file for s352
// Yuho v5 Syntax

referencing penal_code/s352_punishment_using_criminal_force_otherwise

struct S352CaseTest {
    bool offenceCommitted,
}

S352CaseTest convicted := S352CaseTest {
    offenceCommitted := TRUE,
}

assert s352_applies(convicted.offenceCommitted) == TRUE

S352CaseTest acquitted := S352CaseTest {
    offenceCommitted := FALSE,
}

assert s352_applies(acquitted.offenceCommitted) == FALSE
