// Test file for s114
// Yuho v5 Syntax

referencing penal_code/s114_abettor_present_when_offence_committed

struct S114Test {
    bool wouldBePunishableIfAbsent,
    bool presentWhenCommitted,
}

S114Test present := S114Test {
    wouldBePunishableIfAbsent := TRUE,
    presentWhenCommitted := TRUE,
}
assert s114_deemed_committed(present.wouldBePunishableIfAbsent, present.presentWhenCommitted) == TRUE

S114Test absent := S114Test {
    wouldBePunishableIfAbsent := TRUE,
    presentWhenCommitted := FALSE,
}
assert s114_deemed_committed(absent.wouldBePunishableIfAbsent, absent.presentWhenCommitted) == FALSE
