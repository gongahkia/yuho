// Test file for s276
// Yuho v5 Syntax

referencing penal_code/s276_sale_drug_different_drug_preparation

struct SaleDifferentTestCase { bool sold, bool asDifferent, bool knowingly, }
SaleDifferentTestCase good := SaleDifferentTestCase { sold := TRUE, asDifferent := TRUE, knowingly := TRUE, }
assert is_offence(good.sold, good.asDifferent, good.knowingly) == TRUE
SaleDifferentTestCase honest := SaleDifferentTestCase { sold := TRUE, asDifferent := TRUE, knowingly := FALSE, }
assert is_offence(honest.sold, honest.asDifferent, honest.knowingly) == FALSE
