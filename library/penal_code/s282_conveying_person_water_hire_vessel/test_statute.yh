// Test file for s282
// Yuho v5 Syntax

referencing penal_code/s282_conveying_person_water_hire_vessel

struct ConveyTestCase { bool conveyed, bool forHire, bool unsafe, bool mens, }
ConveyTestCase good := ConveyTestCase { conveyed := TRUE, forHire := TRUE, unsafe := TRUE, mens := TRUE, }
assert is_offence(good.conveyed, good.forHire, good.unsafe, good.mens) == TRUE
ConveyTestCase freeride := ConveyTestCase { conveyed := TRUE, forHire := FALSE, unsafe := TRUE, mens := TRUE, }
assert is_offence(freeride.conveyed, freeride.forHire, freeride.unsafe, freeride.mens) == FALSE
