// Test file for s335A
// Yuho v5 Syntax

referencing penal_code/s335A_allowing_neglect_physical_sexual_abuse

struct S335aCaseTest {
    bool actusReus,
    bool mensRea,
}

S335aCaseTest satisfied := S335aCaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s335a_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S335aCaseTest missingMens := S335aCaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s335a_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
