// Test file for s504_intentional_insult_intent_provoke_breach

referencing penal_code/s504_intentional_insult_intent_provoke_breach

struct IntentionalInsultIntentProvokeTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

IntentionalInsultIntentProvokeTestCase guilty := IntentionalInsultIntentProvokeTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_intentional_insult_intent_provoke(guilty.elements_satisfied, guilty.defence_applies) == TRUE

IntentionalInsultIntentProvokeTestCase defended := IntentionalInsultIntentProvokeTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_intentional_insult_intent_provoke(defended.elements_satisfied, defended.defence_applies) == FALSE

IntentionalInsultIntentProvokeTestCase notMadeOut := IntentionalInsultIntentProvokeTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_intentional_insult_intent_provoke(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
