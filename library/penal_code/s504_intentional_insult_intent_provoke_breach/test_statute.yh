// Test file for s504_intentional_insult_intent_provoke_breach
// Yuho v5 Syntax

referencing penal_code/s504_intentional_insult_intent_provoke_breach

struct IntentionalInsultCaseTest {
    bool elementsSatisfied,
}

IntentionalInsultCaseTest positive := IntentionalInsultCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

IntentionalInsultCaseTest negative := IntentionalInsultCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
