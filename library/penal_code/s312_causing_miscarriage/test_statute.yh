// Test file for s312_causing_miscarriage

referencing penal_code/s312_causing_miscarriage

struct CausingMiscarriageTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CausingMiscarriageTestCase guilty := CausingMiscarriageTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_causing_miscarriage(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CausingMiscarriageTestCase defended := CausingMiscarriageTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_causing_miscarriage(defended.elements_satisfied, defended.defence_applies) == FALSE

CausingMiscarriageTestCase notMadeOut := CausingMiscarriageTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_causing_miscarriage(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
