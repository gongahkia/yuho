// Test file for s291
// Yuho v5 Syntax

referencing penal_code/s291_continuance_nuisance_after_injunction

struct S291CaseTestCase {
    bool publicNuisance,
    bool lawfulInjunction,
    bool repeatOrContinue,
}

S291CaseTestCase matching := S291CaseTestCase {
    publicNuisance := TRUE,
    lawfulInjunction := TRUE,
    repeatOrContinue := TRUE,
}

assert applies_s291(matching.publicNuisance, matching.lawfulInjunction, matching.repeatOrContinue) == TRUE

S291CaseTestCase missing := S291CaseTestCase {
    publicNuisance := FALSE,
    lawfulInjunction := TRUE,
    repeatOrContinue := TRUE,
}

assert applies_s291(missing.publicNuisance, missing.lawfulInjunction, missing.repeatOrContinue) == FALSE
