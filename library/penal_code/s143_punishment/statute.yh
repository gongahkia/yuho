/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr143-#pr143-

statute 143 "Punishment" effective 1872-01-01 {
    /// Punishment for being a member of an unlawful assembly; see sections 141 and 142 for the underlying offence context.
    penalty or_both {
        imprisonment := 0 days .. 2 years;
        fine := unlimited;
    }
}
