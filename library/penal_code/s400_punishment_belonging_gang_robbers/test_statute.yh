// Test file for s400_punishment_belonging_gang_robbers
// Yuho v5 Syntax

referencing penal_code/s400_punishment_belonging_gang_robbers

struct S400TestCase {
    bool belongsToGang,
    bool gangHabituallyCommitsGangRobbery,
}

S400TestCase member := S400TestCase {
    belongsToGang := TRUE,
    gangHabituallyCommitsGangRobbery := TRUE,
}

assert s400_applies(member.belongsToGang, member.gangHabituallyCommitsGangRobbery) == TRUE

S400TestCase outsider := S400TestCase {
    belongsToGang := FALSE,
    gangHabituallyCommitsGangRobbery := TRUE,
}

assert s400_applies(outsider.belongsToGang, outsider.gangHabituallyCommitsGangRobbery) == FALSE
