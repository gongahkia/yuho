// Test file for s477_fraudulent_cancellation_destruction_etc_will
// Yuho v5 Syntax

referencing penal_code/s477_fraudulent_cancellation_destruction_etc_will

struct FraudulentCancellationWillCaseTest {
    bool elementsSatisfied,
}

FraudulentCancellationWillCaseTest positive := FraudulentCancellationWillCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

FraudulentCancellationWillCaseTest negative := FraudulentCancellationWillCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
