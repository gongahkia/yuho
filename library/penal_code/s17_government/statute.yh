/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr17-#pr17-
// Singapore Penal Code Section 17 - "Government"
// Shape: interpretation / definition

statute 17 "Government" effective 1872-01-01 {
    definitions {
        government := "Any person lawfully performing executive functions of the Government under any law";
    }
}
