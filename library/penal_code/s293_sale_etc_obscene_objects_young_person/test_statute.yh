// Test file for s293
// Yuho v5 Syntax

referencing penal_code/s293_sale_etc_obscene_objects_young_person

struct S293CaseTestCase {
    bool obsceneObjectUnderSection292,
    bool recipientBelowTwentyOne,
    bool saleHireDistributionExhibitionCirculationOrOffer,
}

S293CaseTestCase matching := S293CaseTestCase {
    obsceneObjectUnderSection292 := TRUE,
    recipientBelowTwentyOne := TRUE,
    saleHireDistributionExhibitionCirculationOrOffer := TRUE,
}

assert applies_s293(matching.obsceneObjectUnderSection292, matching.recipientBelowTwentyOne, matching.saleHireDistributionExhibitionCirculationOrOffer) == TRUE

S293CaseTestCase missing := S293CaseTestCase {
    obsceneObjectUnderSection292 := FALSE,
    recipientBelowTwentyOne := TRUE,
    saleHireDistributionExhibitionCirculationOrOffer := TRUE,
}

assert applies_s293(missing.obsceneObjectUnderSection292, missing.recipientBelowTwentyOne, missing.saleHireDistributionExhibitionCirculationOrOffer) == FALSE
