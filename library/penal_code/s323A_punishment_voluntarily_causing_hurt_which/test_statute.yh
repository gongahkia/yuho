// Test file for s323A
// Yuho v5 Syntax

referencing penal_code/s323A_punishment_voluntarily_causing_hurt_which

struct S323aCaseTest {
    bool offenceCommitted,
}

S323aCaseTest convicted := S323aCaseTest {
    offenceCommitted := TRUE,
}

assert s323a_applies(convicted.offenceCommitted) == TRUE

S323aCaseTest acquitted := S323aCaseTest {
    offenceCommitted := FALSE,
}

assert s323a_applies(acquitted.offenceCommitted) == FALSE
