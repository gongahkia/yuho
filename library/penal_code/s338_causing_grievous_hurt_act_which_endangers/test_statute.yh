// Test file for s338
// Yuho v5 Syntax

referencing penal_code/s338_causing_grievous_hurt_act_which_endangers

struct S338CaseTest {
    bool actusReus,
    bool mensRea,
}

S338CaseTest satisfied := S338CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s338_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S338CaseTest missingMens := S338CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s338_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
