// Test file for s347
// Yuho v5 Syntax

referencing penal_code/s347_wrongful_confinement_purpose_extorting

struct S347CaseTest {
    bool actusReus,
    bool mensRea,
}

S347CaseTest satisfied := S347CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s347_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S347CaseTest missingMens := S347CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s347_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
