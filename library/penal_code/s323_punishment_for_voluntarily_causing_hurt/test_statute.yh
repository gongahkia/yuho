// Test file for s323_punishment_for_voluntarily_causing_hurt

referencing penal_code/s323_punishment_for_voluntarily_causing_hurt


struct S323TestCase {
    bool voluntaryHurtCommitted,
}


S323TestCase guilty := S323TestCase {
    voluntaryHurtCommitted := TRUE,
}

assert guilty.voluntaryHurtCommitted == TRUE
assert s323_applies(guilty.voluntaryHurtCommitted) == TRUE


S323TestCase notGuilty := S323TestCase {
    voluntaryHurtCommitted := FALSE,
}

assert notGuilty.voluntaryHurtCommitted == FALSE
assert s323_applies(notGuilty.voluntaryHurtCommitted) == FALSE
