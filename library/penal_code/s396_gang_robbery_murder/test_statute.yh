// Test file for s396_gang_robbery_murder
// Yuho v5 Syntax

referencing penal_code/s396_gang_robbery_murder

struct S396TestCase {
    bool gangRobberyInProgress,
    bool murderCommittedByMember,
}

S396TestCase fatalGang := S396TestCase {
    gangRobberyInProgress := TRUE,
    murderCommittedByMember := TRUE,
}

assert s396_applies(fatalGang.gangRobberyInProgress, fatalGang.murderCommittedByMember) == TRUE

S396TestCase plainGang := S396TestCase {
    gangRobberyInProgress := TRUE,
    murderCommittedByMember := FALSE,
}

assert s396_applies(plainGang.gangRobberyInProgress, plainGang.murderCommittedByMember) == FALSE
