// Test file for s406_punishment_for_criminal_breach_of_trust

referencing penal_code/s406_punishment_for_criminal_breach_of_trust


struct S406TestCase {
    bool breachOfTrustCommitted,
}


S406TestCase guilty := S406TestCase {
    breachOfTrustCommitted := TRUE,
}

assert guilty.breachOfTrustCommitted == TRUE
assert s406_applies(guilty.breachOfTrustCommitted) == TRUE


S406TestCase notGuilty := S406TestCase {
    breachOfTrustCommitted := FALSE,
}

assert notGuilty.breachOfTrustCommitted == FALSE
assert s406_applies(notGuilty.breachOfTrustCommitted) == FALSE
