// Test file for s332
// Yuho v5 Syntax

referencing penal_code/s332_voluntarily_causing_hurt_deter_public

struct S332CaseTest {
    bool actusReus,
    bool mensRea,
}

S332CaseTest satisfied := S332CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s332_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S332CaseTest missingMens := S332CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s332_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
