// Test file for s304A_causing_death_rash_negligent_act
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s304A_causing_death_rash_negligent_act

struct CausingDeathNegligentTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
CausingDeathNegligentTestCase guilty := CausingDeathNegligentTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_causing_death_negligent(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
CausingDeathNegligentTestCase defended := CausingDeathNegligentTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_causing_death_negligent(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
CausingDeathNegligentTestCase notMadeOut := CausingDeathNegligentTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_causing_death_negligent(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
