// Test file for s473B_making_possessing_equipment_making_false
// Yuho v5 Syntax

referencing penal_code/s473B_making_possessing_equipment_making_false

struct EquipmentFalseInstrumentPrejudiceCaseTest {
    bool elementsSatisfied,
}

EquipmentFalseInstrumentPrejudiceCaseTest positive := EquipmentFalseInstrumentPrejudiceCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

EquipmentFalseInstrumentPrejudiceCaseTest negative := EquipmentFalseInstrumentPrejudiceCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
