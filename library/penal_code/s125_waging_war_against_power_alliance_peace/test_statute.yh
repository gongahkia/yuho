// Test file for s125
// Yuho v5 Syntax

referencing penal_code/s125_waging_war_against_power_alliance_peace

struct S125Test { string mode, }

S125Test waging := S125Test { mode := "wages_war", }
assert s125_applies(waging.mode) == TRUE

S125Test other := S125Test { mode := "minor_infraction", }
assert s125_applies(other.mode) == FALSE
