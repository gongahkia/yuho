// Test file for s112
// Yuho v5 Syntax

referencing penal_code/s112_abettor_when_liable_cumulative_punishment

struct S112Test {
    bool s111Applies,
    bool actDoneInAdditionToActAbetted,
    bool constitutesDistinctOffence,
}

S112Test cumulative := S112Test {
    s111Applies := TRUE,
    actDoneInAdditionToActAbetted := TRUE,
    constitutesDistinctOffence := TRUE,
}
assert s112_cumulative(cumulative.s111Applies, cumulative.actDoneInAdditionToActAbetted, cumulative.constitutesDistinctOffence) == TRUE

S112Test notDistinct := S112Test {
    s111Applies := TRUE,
    actDoneInAdditionToActAbetted := TRUE,
    constitutesDistinctOffence := FALSE,
}
assert s112_cumulative(notDistinct.s111Applies, notDistinct.actDoneInAdditionToActAbetted, notDistinct.constitutesDistinctOffence) == FALSE
