// Test file for s468_forgery_purpose_cheating

referencing penal_code/s468_forgery_purpose_cheating

struct ForgeryPurposeCheatingTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

ForgeryPurposeCheatingTestCase guilty := ForgeryPurposeCheatingTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_forgery_purpose_cheating(guilty.elements_satisfied, guilty.defence_applies) == TRUE

ForgeryPurposeCheatingTestCase defended := ForgeryPurposeCheatingTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_forgery_purpose_cheating(defended.elements_satisfied, defended.defence_applies) == FALSE

ForgeryPurposeCheatingTestCase notMadeOut := ForgeryPurposeCheatingTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_forgery_purpose_cheating(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
