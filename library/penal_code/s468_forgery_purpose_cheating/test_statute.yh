// Test file for s468_forgery_purpose_cheating
// Yuho v5 Syntax

referencing penal_code/s468_forgery_purpose_cheating

struct ForgeryForCheatingCaseTest {
    bool elementsSatisfied,
}

ForgeryForCheatingCaseTest positive := ForgeryForCheatingCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

ForgeryForCheatingCaseTest negative := ForgeryForCheatingCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
