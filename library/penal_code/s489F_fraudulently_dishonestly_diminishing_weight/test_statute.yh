// Test file for s489F_fraudulently_dishonestly_diminishing_weight
// Yuho v5 Syntax

referencing penal_code/s489F_fraudulently_dishonestly_diminishing_weight

struct DiminishingCoinCaseTest {
    bool elementsSatisfied,
}

DiminishingCoinCaseTest positive := DiminishingCoinCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

DiminishingCoinCaseTest negative := DiminishingCoinCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
