// Test file for s477A_falsification_accounts

referencing penal_code/s477A_falsification_accounts

struct FalsificationOfAccountsTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

FalsificationOfAccountsTestCase guilty := FalsificationOfAccountsTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_falsification_of_accounts(guilty.elements_satisfied, guilty.defence_applies) == TRUE

FalsificationOfAccountsTestCase defended := FalsificationOfAccountsTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_falsification_of_accounts(defended.elements_satisfied, defended.defence_applies) == FALSE

FalsificationOfAccountsTestCase notMadeOut := FalsificationOfAccountsTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_falsification_of_accounts(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
