// Test file for s477A_falsification_accounts
// Yuho v5 Syntax

referencing penal_code/s477A_falsification_accounts

struct FalsificationAccountsCaseTest {
    bool elementsSatisfied,
}

FalsificationAccountsCaseTest positive := FalsificationAccountsCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

FalsificationAccountsCaseTest negative := FalsificationAccountsCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
