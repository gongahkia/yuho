// Test file for s351_assault
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s351_assault

struct AssaultTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
AssaultTestCase guilty := AssaultTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_assault(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
AssaultTestCase defended := AssaultTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_assault(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
AssaultTestCase notMadeOut := AssaultTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_assault(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
