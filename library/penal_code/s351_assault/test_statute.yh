// Test file for s351
// Yuho v5 Syntax

referencing penal_code/s351_assault

struct S351CaseTest {
    bool criteriaMet,
}

S351CaseTest matches := S351CaseTest {
    criteriaMet := TRUE,
}

assert s351_matches(matches.criteriaMet) == TRUE

S351CaseTest nomatch := S351CaseTest {
    criteriaMet := FALSE,
}

assert s351_matches(nomatch.criteriaMet) == FALSE
