// Test file for s204A_obstructing_preventing_perverting_defeating
// Yuho v5 Syntax

referencing penal_code/s204A_obstructing_preventing_perverting_defeating

struct S204ATestCase {
    bool tendsToObstructPreventPervertDefeat,
    bool knowsLikelyToObstruct,
    bool intendsToObstruct,
}

S204ATestCase intentionalTamper := S204ATestCase {
    tendsToObstructPreventPervertDefeat := TRUE,
    knowsLikelyToObstruct := FALSE,
    intendsToObstruct := TRUE,
}

assert evaluate_s204A(intentionalTamper.tendsToObstructPreventPervertDefeat, intentionalTamper.knowsLikelyToObstruct, intentionalTamper.intendsToObstruct) == "Liable under s204A"

S204ATestCase innocentAct := S204ATestCase {
    tendsToObstructPreventPervertDefeat := TRUE,
    knowsLikelyToObstruct := FALSE,
    intendsToObstruct := FALSE,
}

assert evaluate_s204A(innocentAct.tendsToObstructPreventPervertDefeat, innocentAct.knowsLikelyToObstruct, innocentAct.intendsToObstruct) == "Not liable - no mens rea"
