// Test file for s121
// Yuho v5 Syntax

referencing penal_code/s121_waging_attempting_wage_war_abetting_waging

struct S121Test {
    string mode,
}

S121Test waging := S121Test { mode := "wages_war", }
assert s121_applies(waging.mode) == TRUE

S121Test unrelated := S121Test { mode := "petty_theft", }
assert s121_applies(unrelated.mode) == FALSE
