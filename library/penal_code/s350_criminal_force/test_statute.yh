// Test file for s350_criminal_force

referencing penal_code/s350_criminal_force

struct CriminalForceTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CriminalForceTestCase guilty := CriminalForceTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_criminal_force(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CriminalForceTestCase defended := CriminalForceTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_criminal_force(defended.elements_satisfied, defended.defence_applies) == FALSE

CriminalForceTestCase notMadeOut := CriminalForceTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_criminal_force(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
