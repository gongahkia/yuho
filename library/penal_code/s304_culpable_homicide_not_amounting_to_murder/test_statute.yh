// Test file for s304_culpable_homicide_not_amounting_to_murder

referencing penal_code/s304_culpable_homicide_not_amounting_to_murder


struct S304TestCase {
    string intention,
    bool deathCaused,
    bool amountsToMurder,
}


S304TestCase intentDeath := S304TestCase {
    intention := "cause_death",
    deathCaused := TRUE,
    amountsToMurder := FALSE,
}

assert intentDeath.intention == "cause_death"
assert is_s304_offence(intentDeath.intention, intentDeath.deathCaused, intentDeath.amountsToMurder) == TRUE


S304TestCase knowledgeDeath := S304TestCase {
    intention := "knowledge_likely_to_cause_death",
    deathCaused := TRUE,
    amountsToMurder := FALSE,
}

assert is_s304_offence(knowledgeDeath.intention, knowledgeDeath.deathCaused, knowledgeDeath.amountsToMurder) == TRUE


S304TestCase isMurder := S304TestCase {
    intention := "cause_death",
    deathCaused := TRUE,
    amountsToMurder := TRUE,
}

assert is_s304_offence(isMurder.intention, isMurder.deathCaused, isMurder.amountsToMurder) == FALSE


S304TestCase noDeath := S304TestCase {
    intention := "cause_death",
    deathCaused := FALSE,
    amountsToMurder := FALSE,
}

assert is_s304_offence(noDeath.intention, noDeath.deathCaused, noDeath.amountsToMurder) == FALSE


S304TestCase noIntention := S304TestCase {
    intention := "none",
    deathCaused := TRUE,
    amountsToMurder := FALSE,
}

assert is_s304_offence(noIntention.intention, noIntention.deathCaused, noIntention.amountsToMurder) == FALSE
