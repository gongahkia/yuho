// Test file for s106A_acts_against_which_there_no_right_private
// Yuho v5 Syntax

referencing penal_code/s106A_acts_against_which_there_no_right_private

struct NoDefenceTestCase {
    bool actorIsPublicServant,
    bool actorInGoodFaith,
    bool defenderBelievesDeathOrGrievousHurt,
    bool defenderKnowsActorIsPublicServant,
}

// public servant in good faith, no belief of grievous hurt, defender knows -> no right of defence
NoDefenceTestCase blockedCase := NoDefenceTestCase {
    actorIsPublicServant := TRUE,
    actorInGoodFaith := TRUE,
    defenderBelievesDeathOrGrievousHurt := FALSE,
    defenderKnowsActorIsPublicServant := TRUE,
}

assert no_right_of_defence(blockedCase.actorIsPublicServant, blockedCase.actorInGoodFaith, blockedCase.defenderBelievesDeathOrGrievousHurt, blockedCase.defenderKnowsActorIsPublicServant) == TRUE

// defender reasonably believes grievous hurt -> right restored
NoDefenceTestCase graveBeliefCase := NoDefenceTestCase {
    actorIsPublicServant := TRUE,
    actorInGoodFaith := TRUE,
    defenderBelievesDeathOrGrievousHurt := TRUE,
    defenderKnowsActorIsPublicServant := TRUE,
}

assert no_right_of_defence(graveBeliefCase.actorIsPublicServant, graveBeliefCase.actorInGoodFaith, graveBeliefCase.defenderBelievesDeathOrGrievousHurt, graveBeliefCase.defenderKnowsActorIsPublicServant) == FALSE

// defender does not know actor is public servant -> right preserved
NoDefenceTestCase unknowingCase := NoDefenceTestCase {
    actorIsPublicServant := TRUE,
    actorInGoodFaith := TRUE,
    defenderBelievesDeathOrGrievousHurt := FALSE,
    defenderKnowsActorIsPublicServant := FALSE,
}

assert no_right_of_defence(unknowingCase.actorIsPublicServant, unknowingCase.actorInGoodFaith, unknowingCase.defenderBelievesDeathOrGrievousHurt, unknowingCase.defenderKnowsActorIsPublicServant) == FALSE
