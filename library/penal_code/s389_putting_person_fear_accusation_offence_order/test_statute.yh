// Test file for s389_putting_person_fear_accusation_offence_order
// Yuho v5 Syntax

referencing penal_code/s389_putting_person_fear_accusation_offence_order

struct S389TestCase {
    bool extortionIntent,
    bool fearOfSeriousAccusation,
}

S389TestCase attempt := S389TestCase {
    extortionIntent := TRUE,
    fearOfSeriousAccusation := TRUE,
}

assert s389_applies(attempt.extortionIntent, attempt.fearOfSeriousAccusation) == TRUE

S389TestCase idle := S389TestCase {
    extortionIntent := FALSE,
    fearOfSeriousAccusation := TRUE,
}

assert s389_applies(idle.extortionIntent, idle.fearOfSeriousAccusation) == FALSE
