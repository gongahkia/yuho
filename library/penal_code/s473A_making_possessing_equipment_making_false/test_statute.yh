// Test file for s473A_making_possessing_equipment_making_false
// Yuho v5 Syntax

referencing penal_code/s473A_making_possessing_equipment_making_false

struct EquipmentFalseInstrumentCaseTest {
    bool elementsSatisfied,
}

EquipmentFalseInstrumentCaseTest positive := EquipmentFalseInstrumentCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

EquipmentFalseInstrumentCaseTest negative := EquipmentFalseInstrumentCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
