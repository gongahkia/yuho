// Test file for s329_voluntarily_causing_grievous_hurt_extort

referencing penal_code/s329_voluntarily_causing_grievous_hurt_extort

struct VoluntarilyCausingGrievousHurtTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

VoluntarilyCausingGrievousHurtTestCase guilty := VoluntarilyCausingGrievousHurtTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_s329_voluntarily_causing_grievous_hurt(guilty.elements_satisfied, guilty.defence_applies) == TRUE

VoluntarilyCausingGrievousHurtTestCase defended := VoluntarilyCausingGrievousHurtTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_s329_voluntarily_causing_grievous_hurt(defended.elements_satisfied, defended.defence_applies) == FALSE

VoluntarilyCausingGrievousHurtTestCase notMadeOut := VoluntarilyCausingGrievousHurtTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_s329_voluntarily_causing_grievous_hurt(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
