// Test file for s313
// Yuho v5 Syntax

referencing penal_code/s313_causing_miscarriage_without_woman_s_consent

struct S313CaseTest {
    bool actusReus,
    bool mensRea,
}

S313CaseTest satisfied := S313CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s313_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S313CaseTest missingMens := S313CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s313_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
