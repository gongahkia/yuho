// Test file for s269_negligent_act_likely_spread_infection

referencing penal_code/s269_negligent_act_likely_spread_infection

struct NegligentActLikelySpreadTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

NegligentActLikelySpreadTestCase guilty := NegligentActLikelySpreadTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_negligent_act_likely_spread(guilty.elements_satisfied, guilty.defence_applies) == TRUE

NegligentActLikelySpreadTestCase defended := NegligentActLikelySpreadTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_negligent_act_likely_spread(defended.elements_satisfied, defended.defence_applies) == FALSE

NegligentActLikelySpreadTestCase notMadeOut := NegligentActLikelySpreadTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_negligent_act_likely_spread(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
