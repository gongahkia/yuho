// Test file for s269
// Yuho v5 Syntax

referencing penal_code/s269_negligent_act_likely_spread_infection

struct NegligentInfectionTestCase {
    bool actDone,
    bool unlawfulOrNegligent,
    bool knowledgeOrReasonToBelieve,
    bool likelyToSpreadInfection,
    bool diseaseDangerousToLife,
}

// ----- passing case: all elements satisfied -----

NegligentInfectionTestCase allElements := NegligentInfectionTestCase {
    actDone := TRUE,
    unlawfulOrNegligent := TRUE,
    knowledgeOrReasonToBelieve := TRUE,
    likelyToSpreadInfection := TRUE,
    diseaseDangerousToLife := TRUE,
}

assert is_offence(allElements.actDone, allElements.unlawfulOrNegligent, allElements.knowledgeOrReasonToBelieve, allElements.likelyToSpreadInfection, allElements.diseaseDangerousToLife) == TRUE

// ----- failing case: no knowledge -----

NegligentInfectionTestCase noKnowledge := NegligentInfectionTestCase {
    actDone := TRUE,
    unlawfulOrNegligent := TRUE,
    knowledgeOrReasonToBelieve := FALSE,
    likelyToSpreadInfection := TRUE,
    diseaseDangerousToLife := TRUE,
}

assert is_offence(noKnowledge.actDone, noKnowledge.unlawfulOrNegligent, noKnowledge.knowledgeOrReasonToBelieve, noKnowledge.likelyToSpreadInfection, noKnowledge.diseaseDangerousToLife) == FALSE
