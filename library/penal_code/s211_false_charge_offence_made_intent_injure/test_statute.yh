// Test file for s211_false_charge_offence_made_intent_injure
// Yuho v5 Syntax

referencing penal_code/s211_false_charge_offence_made_intent_injure

struct S211TestCase {
    bool institutesProceedingOrFalselyCharges,
    bool intentToCauseInjury,
    bool knowsNoJustOrLawfulGround,
    bool chargeIsCapitalOr7YearsPlus,
}

S211TestCase falseMurderCharge := S211TestCase {
    institutesProceedingOrFalselyCharges := TRUE,
    intentToCauseInjury := TRUE,
    knowsNoJustOrLawfulGround := TRUE,
    chargeIsCapitalOr7YearsPlus := TRUE,
}

assert evaluate_s211(falseMurderCharge.institutesProceedingOrFalselyCharges, falseMurderCharge.intentToCauseInjury, falseMurderCharge.knowsNoJustOrLawfulGround, falseMurderCharge.chargeIsCapitalOr7YearsPlus) == "Liable under s211 - aggravated (up to 7 years)"

S211TestCase simpleFalseCharge := S211TestCase {
    institutesProceedingOrFalselyCharges := TRUE,
    intentToCauseInjury := TRUE,
    knowsNoJustOrLawfulGround := TRUE,
    chargeIsCapitalOr7YearsPlus := FALSE,
}

assert evaluate_s211(simpleFalseCharge.institutesProceedingOrFalselyCharges, simpleFalseCharge.intentToCauseInjury, simpleFalseCharge.knowsNoJustOrLawfulGround, simpleFalseCharge.chargeIsCapitalOr7YearsPlus) == "Liable under s211 - simple (up to 2 years)"

S211TestCase goodFaithComplaint := S211TestCase {
    institutesProceedingOrFalselyCharges := TRUE,
    intentToCauseInjury := FALSE,
    knowsNoJustOrLawfulGround := FALSE,
    chargeIsCapitalOr7YearsPlus := FALSE,
}

assert evaluate_s211(goodFaithComplaint.institutesProceedingOrFalselyCharges, goodFaithComplaint.intentToCauseInjury, goodFaithComplaint.knowsNoJustOrLawfulGround, goodFaithComplaint.chargeIsCapitalOr7YearsPlus) == "Not liable - no intent to injure"
