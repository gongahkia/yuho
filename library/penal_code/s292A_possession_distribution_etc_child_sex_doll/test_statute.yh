// Test file for s292A
// Yuho v5 Syntax

referencing penal_code/s292A_possession_distribution_etc_child_sex_doll

struct S292ACaseTestCase {
    bool childSexDoll,
    bool prohibitedDealing,
}

S292ACaseTestCase matching := S292ACaseTestCase {
    childSexDoll := TRUE,
    prohibitedDealing := TRUE,
}

assert applies_s292a(matching.childSexDoll, matching.prohibitedDealing) == TRUE

S292ACaseTestCase missing := S292ACaseTestCase {
    childSexDoll := FALSE,
    prohibitedDealing := TRUE,
}

assert applies_s292a(missing.childSexDoll, missing.prohibitedDealing) == FALSE
