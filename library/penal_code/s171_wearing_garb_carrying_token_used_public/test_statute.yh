// Test file for s171_wearing_garb_carrying_token_used_public

referencing penal_code/s171_wearing_garb_carrying_token_used_public

struct WearingGarbCarryingTokenTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

WearingGarbCarryingTokenTestCase guilty := WearingGarbCarryingTokenTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_wearing_garb_carrying_token(guilty.elements_satisfied, guilty.defence_applies) == TRUE

WearingGarbCarryingTokenTestCase defended := WearingGarbCarryingTokenTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_wearing_garb_carrying_token(defended.elements_satisfied, defended.defence_applies) == FALSE

WearingGarbCarryingTokenTestCase notMadeOut := WearingGarbCarryingTokenTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_wearing_garb_carrying_token(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
