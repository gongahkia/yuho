// Test file for s192_fabricating_false_evidence
// Yuho v5 Syntax

referencing penal_code/s192_fabricating_false_evidence

struct S192TestCase {
    bool causesCircumstanceOrFalseEntry,
    bool intendsToAppearInEvidence,
    bool intendsErroneousOpinion,
}

S192TestCase plantingJewels := S192TestCase {
    causesCircumstanceOrFalseEntry := TRUE,
    intendsToAppearInEvidence := TRUE,
    intendsErroneousOpinion := TRUE,
}

assert evaluate_s192(plantingJewels.causesCircumstanceOrFalseEntry, plantingJewels.intendsToAppearInEvidence, plantingJewels.intendsErroneousOpinion) == "Said to fabricate false evidence"

S192TestCase noIntent := S192TestCase {
    causesCircumstanceOrFalseEntry := TRUE,
    intendsToAppearInEvidence := FALSE,
    intendsErroneousOpinion := TRUE,
}

assert evaluate_s192(noIntent.causesCircumstanceOrFalseEntry, noIntent.intendsToAppearInEvidence, noIntent.intendsErroneousOpinion) == "Not fabricating - no intent for evidence use"

S192TestCase noFalsity := S192TestCase {
    causesCircumstanceOrFalseEntry := FALSE,
    intendsToAppearInEvidence := TRUE,
    intendsErroneousOpinion := TRUE,
}

assert evaluate_s192(noFalsity.causesCircumstanceOrFalseEntry, noFalsity.intendsToAppearInEvidence, noFalsity.intendsErroneousOpinion) == "Not fabricating - no false circumstance or entry"
