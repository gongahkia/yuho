// Test file for s202_intentional_omission_give_information
// Yuho v5 Syntax

referencing penal_code/s202_intentional_omission_give_information

struct S202TestCase {
    bool knowsOrReasonToBelieveOffenceCommitted,
    bool legallyBoundToGiveInformation,
    bool intentionallyOmits,
}

S202TestCase silentBoundInformer := S202TestCase {
    knowsOrReasonToBelieveOffenceCommitted := TRUE,
    legallyBoundToGiveInformation := TRUE,
    intentionallyOmits := TRUE,
}

assert evaluate_s202(silentBoundInformer.knowsOrReasonToBelieveOffenceCommitted, silentBoundInformer.legallyBoundToGiveInformation, silentBoundInformer.intentionallyOmits) == "Liable under s202"

S202TestCase noDuty := S202TestCase {
    knowsOrReasonToBelieveOffenceCommitted := TRUE,
    legallyBoundToGiveInformation := FALSE,
    intentionallyOmits := TRUE,
}

assert evaluate_s202(noDuty.knowsOrReasonToBelieveOffenceCommitted, noDuty.legallyBoundToGiveInformation, noDuty.intentionallyOmits) == "Not liable - no legal duty to inform"
