// Test file for s325_voluntarily_causing_grievous_hurt

referencing penal_code/s325_voluntarily_causing_grievous_hurt


struct S325TestCase {
    string hurtType,
    bool intentToCauseGrievousHurt,
    bool grievousHurtCaused,
}


S325TestCase blindingCase := S325TestCase {
    hurtType := "permanent_privation_of_sight",
    intentToCauseGrievousHurt := TRUE,
    grievousHurtCaused := TRUE,
}

assert is_grievous_hurt(blindingCase.hurtType, blindingCase.intentToCauseGrievousHurt, blindingCase.grievousHurtCaused) == TRUE


S325TestCase fractureCase := S325TestCase {
    hurtType := "fracture_or_dislocation",
    intentToCauseGrievousHurt := TRUE,
    grievousHurtCaused := TRUE,
}

assert is_grievous_hurt(fractureCase.hurtType, fractureCase.intentToCauseGrievousHurt, fractureCase.grievousHurtCaused) == TRUE


S325TestCase noIntent := S325TestCase {
    hurtType := "fracture_or_dislocation",
    intentToCauseGrievousHurt := FALSE,
    grievousHurtCaused := TRUE,
}

assert is_grievous_hurt(noIntent.hurtType, noIntent.intentToCauseGrievousHurt, noIntent.grievousHurtCaused) == FALSE


S325TestCase noGrievousHurt := S325TestCase {
    hurtType := "fracture_or_dislocation",
    intentToCauseGrievousHurt := TRUE,
    grievousHurtCaused := FALSE,
}

assert is_grievous_hurt(noGrievousHurt.hurtType, noGrievousHurt.intentToCauseGrievousHurt, noGrievousHurt.grievousHurtCaused) == FALSE


S325TestCase minorHurt := S325TestCase {
    hurtType := "bruise",
    intentToCauseGrievousHurt := TRUE,
    grievousHurtCaused := TRUE,
}

assert is_grievous_hurt(minorHurt.hurtType, minorHurt.intentToCauseGrievousHurt, minorHurt.grievousHurtCaused) == FALSE
