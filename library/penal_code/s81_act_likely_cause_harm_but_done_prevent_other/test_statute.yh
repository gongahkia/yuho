// test file for s81 - necessity defence
referencing penal_code/s81_act_likely_cause_harm_but_done_prevent_other

struct NecessityTestCase {
    bool knewLikelyHarm,
    bool goodFaith,
    string purpose,
    bool harmImminent,
}

// classic necessity: captain diverts vessel to avoid greater harm
NecessityTestCase captain := NecessityTestCase {
    knewLikelyHarm := TRUE,
    goodFaith := TRUE,
    purpose := "prevent_other_harm",
    harmImminent := TRUE,
}

assert is_necessity_defence(captain.knewLikelyHarm, captain.goodFaith, captain.purpose, captain.harmImminent) == TRUE

// bad faith: defence fails
NecessityTestCase badFaith := NecessityTestCase {
    knewLikelyHarm := TRUE,
    goodFaith := FALSE,
    purpose := "prevent_other_harm",
    harmImminent := TRUE,
}

assert is_necessity_defence(badFaith.knewLikelyHarm, badFaith.goodFaith, badFaith.purpose, badFaith.harmImminent) == FALSE

// non-imminent harm: defence fails
NecessityTestCase notImminent := NecessityTestCase {
    knewLikelyHarm := TRUE,
    goodFaith := TRUE,
    purpose := "prevent_other_harm",
    harmImminent := FALSE,
}

assert is_necessity_defence(notImminent.knewLikelyHarm, notImminent.goodFaith, notImminent.purpose, notImminent.harmImminent) == FALSE
