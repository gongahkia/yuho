// Test file for s506_punishment_criminal_intimidation

referencing penal_code/s506_punishment_criminal_intimidation

struct PunishmentCriminalIntimidationTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

PunishmentCriminalIntimidationTestCase guilty := PunishmentCriminalIntimidationTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_punishment_criminal_intimidation(guilty.elements_satisfied, guilty.defence_applies) == TRUE

PunishmentCriminalIntimidationTestCase defended := PunishmentCriminalIntimidationTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_punishment_criminal_intimidation(defended.elements_satisfied, defended.defence_applies) == FALSE

PunishmentCriminalIntimidationTestCase notMadeOut := PunishmentCriminalIntimidationTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_punishment_criminal_intimidation(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
