// Test file for s506_punishment_criminal_intimidation
// Yuho v5 Syntax

referencing penal_code/s506_punishment_criminal_intimidation

struct CriminalIntimidationPunishmentCaseTest {
    bool offenceCommitted,
}

CriminalIntimidationPunishmentCaseTest convicted := CriminalIntimidationPunishmentCaseTest {
    offenceCommitted := TRUE,
}

assert convicted.offenceCommitted == TRUE
assert punishment_applies(convicted.offenceCommitted) == TRUE

CriminalIntimidationPunishmentCaseTest acquitted := CriminalIntimidationPunishmentCaseTest {
    offenceCommitted := FALSE,
}

assert acquitted.offenceCommitted == FALSE
assert punishment_applies(acquitted.offenceCommitted) == FALSE
