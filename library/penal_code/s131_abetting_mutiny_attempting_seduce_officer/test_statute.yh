// Test file for s131_abetting_mutiny_attempting_seduce_officer

referencing penal_code/s131_abetting_mutiny_attempting_seduce_officer

struct AbettingMutinyAttemptingSeduceTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

AbettingMutinyAttemptingSeduceTestCase guilty := AbettingMutinyAttemptingSeduceTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_abetting_mutiny_attempting_seduce(guilty.elements_satisfied, guilty.defence_applies) == TRUE

AbettingMutinyAttemptingSeduceTestCase defended := AbettingMutinyAttemptingSeduceTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_abetting_mutiny_attempting_seduce(defended.elements_satisfied, defended.defence_applies) == FALSE

AbettingMutinyAttemptingSeduceTestCase notMadeOut := AbettingMutinyAttemptingSeduceTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_abetting_mutiny_attempting_seduce(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
