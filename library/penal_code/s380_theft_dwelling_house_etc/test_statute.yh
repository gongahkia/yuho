// Test file for s380_theft_dwelling_house_etc
// Yuho v5 Syntax — behavioural fixture.
// Universal offence shape: made out iff elements ∧ ¬defence.

referencing penal_code/s380_theft_dwelling_house_etc

struct TheftDwellingHouseEtcTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

// elements satisfied, no defence -> offence made out
TheftDwellingHouseEtcTestCase guilty := TheftDwellingHouseEtcTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_theft_dwelling_house_etc(guilty.elements_satisfied, guilty.defence_applies) == TRUE

// elements satisfied, defence applies -> not made out
TheftDwellingHouseEtcTestCase defended := TheftDwellingHouseEtcTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_theft_dwelling_house_etc(defended.elements_satisfied, defended.defence_applies) == FALSE

// no elements -> not made out
TheftDwellingHouseEtcTestCase notMadeOut := TheftDwellingHouseEtcTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_theft_dwelling_house_etc(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
