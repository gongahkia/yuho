// Test file for s292
// Yuho v5 Syntax

referencing penal_code/s292_sale_obscene_books_etc

struct S292CaseTestCase {
    bool obsceneObject,
    bool prohibitedDealing,
    bool notAuthorisedByWrittenLaw,
    bool notReligiousException,
}

S292CaseTestCase matching := S292CaseTestCase {
    obsceneObject := TRUE,
    prohibitedDealing := TRUE,
    notAuthorisedByWrittenLaw := TRUE,
    notReligiousException := TRUE,
}

assert applies_s292(matching.obsceneObject, matching.prohibitedDealing, matching.notAuthorisedByWrittenLaw, matching.notReligiousException) == TRUE

S292CaseTestCase missing := S292CaseTestCase {
    obsceneObject := FALSE,
    prohibitedDealing := TRUE,
    notAuthorisedByWrittenLaw := TRUE,
    notReligiousException := TRUE,
}

assert applies_s292(missing.obsceneObject, missing.prohibitedDealing, missing.notAuthorisedByWrittenLaw, missing.notReligiousException) == FALSE
