// Test file for s501_printing_engraving_matter_known_defamatory
// Yuho v5 Syntax

referencing penal_code/s501_printing_engraving_matter_known_defamatory

struct PrintingDefamatoryCaseTest {
    bool elementsSatisfied,
}

PrintingDefamatoryCaseTest positive := PrintingDefamatoryCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

PrintingDefamatoryCaseTest negative := PrintingDefamatoryCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
