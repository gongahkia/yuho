// Test file for s392_punishment_for_robbery

referencing penal_code/s392_punishment_for_robbery


struct S392TestCase {
    bool robberyCommitted,
    string timeOfDay,
}


S392TestCase nightRobbery := S392TestCase {
    robberyCommitted := TRUE,
    timeOfDay := "after_7pm_before_7am",
}

assert s392_punishment(nightRobbery.robberyCommitted, nightRobbery.timeOfDay) == "enhanced"


S392TestCase dayRobbery := S392TestCase {
    robberyCommitted := TRUE,
    timeOfDay := "daytime",
}

assert s392_punishment(dayRobbery.robberyCommitted, dayRobbery.timeOfDay) == "standard"


S392TestCase noRobbery := S392TestCase {
    robberyCommitted := FALSE,
    timeOfDay := "daytime",
}

assert s392_punishment(noRobbery.robberyCommitted, noRobbery.timeOfDay) == "none"
