// Test file for s186_obstructing_public_servant_discharge_his
// Yuho v5 Syntax

referencing penal_code/s186_obstructing_public_servant_discharge_his

struct S186TestCase {
    bool voluntary,
    bool obstructsPublicServant,
    bool inDischargeOfPublicFunctions,
}

S186TestCase prankParamedics := S186TestCase {
    voluntary := TRUE,
    obstructsPublicServant := TRUE,
    inDischargeOfPublicFunctions := TRUE,
}

assert prankParamedics.voluntary == TRUE
assert evaluate_s186(prankParamedics.voluntary, prankParamedics.obstructsPublicServant, prankParamedics.inDischargeOfPublicFunctions) == "Liable under s186"

S186TestCase accidental := S186TestCase {
    voluntary := FALSE,
    obstructsPublicServant := TRUE,
    inDischargeOfPublicFunctions := TRUE,
}

assert evaluate_s186(accidental.voluntary, accidental.obstructsPublicServant, accidental.inDischargeOfPublicFunctions) == "Not liable - not voluntary"

S186TestCase offDuty := S186TestCase {
    voluntary := TRUE,
    obstructsPublicServant := TRUE,
    inDischargeOfPublicFunctions := FALSE,
}

assert evaluate_s186(offDuty.voluntary, offDuty.obstructsPublicServant, offDuty.inDischargeOfPublicFunctions) == "Not liable - not in discharge of public function"
