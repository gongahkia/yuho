// Test file for s473_making_possessing_counterfeit_seal_plate_etc
// Yuho v5 Syntax

referencing penal_code/s473_making_possessing_counterfeit_seal_plate_etc

struct CounterfeitSealOtherCaseTest {
    bool elementsSatisfied,
}

CounterfeitSealOtherCaseTest positive := CounterfeitSealOtherCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

CounterfeitSealOtherCaseTest negative := CounterfeitSealOtherCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
