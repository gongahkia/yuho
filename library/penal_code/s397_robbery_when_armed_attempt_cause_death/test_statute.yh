// Test file for s397_robbery_when_armed_attempt_cause_death
// Yuho v5 Syntax

referencing penal_code/s397_robbery_when_armed_attempt_cause_death

struct S397TestCase {
    bool robberyOrAttempt,
    bool armedWithDeadlyWeapon,
    bool grievousHurtCaused,
    bool attemptCauseDeathOrGrievous,
}

S397TestCase armed := S397TestCase {
    robberyOrAttempt := TRUE,
    armedWithDeadlyWeapon := TRUE,
    grievousHurtCaused := FALSE,
    attemptCauseDeathOrGrievous := FALSE,
}

assert s397_applies(armed.robberyOrAttempt, armed.armedWithDeadlyWeapon, armed.grievousHurtCaused, armed.attemptCauseDeathOrGrievous) == TRUE

S397TestCase plain := S397TestCase {
    robberyOrAttempt := TRUE,
    armedWithDeadlyWeapon := FALSE,
    grievousHurtCaused := FALSE,
    attemptCauseDeathOrGrievous := FALSE,
}

assert s397_applies(plain.robberyOrAttempt, plain.armedWithDeadlyWeapon, plain.grievousHurtCaused, plain.attemptCauseDeathOrGrievous) == FALSE
