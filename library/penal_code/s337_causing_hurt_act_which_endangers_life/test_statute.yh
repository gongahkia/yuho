// Test file for s337
// Yuho v5 Syntax

referencing penal_code/s337_causing_hurt_act_which_endangers_life

struct S337CaseTest {
    bool actusReus,
    bool mensRea,
}

S337CaseTest satisfied := S337CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s337_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S337CaseTest missingMens := S337CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s337_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
