/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr374-#pr374-

statute 374 "Unlawful compulsory labour" effective 1872-01-01 {
    elements {
        /// The offence requires unlawful compulsion, labour, and the person's contrary will.
        all_of {
            actus_reus compels_labour := "Whoever unlawfully compels any person to labour";
            circumstance against_will := "Against the will of that person";
        }
    }

    penalty or_both {
        imprisonment := 0 days .. 1 year;
        fine := unlimited;
    }

    exception general_defence_s79 {
        "act done by reason of mistake of fact"
        "no s374 conviction per s79 general exception"
        when is_infringed(s79)
    }
    exception general_defence_s84 {
        "act done by a person of unsound mind"
        "no s374 conviction per s84 general exception"
        when is_infringed(s84)
    }
}
