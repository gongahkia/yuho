// Test file for s301
// Yuho v5 Syntax

referencing penal_code/s301_culpable_homicide_causing_death_person_other

struct S301CaseTestCase {
    bool intendedOrKnownLikelyDeath,
    bool actualDifferentVictimDeath,
    bool culpableHomicideCommitted,
}

S301CaseTestCase matching := S301CaseTestCase {
    intendedOrKnownLikelyDeath := TRUE,
    actualDifferentVictimDeath := TRUE,
    culpableHomicideCommitted := TRUE,
}

assert applies_s301(matching.intendedOrKnownLikelyDeath, matching.actualDifferentVictimDeath, matching.culpableHomicideCommitted) == TRUE

S301CaseTestCase missing := S301CaseTestCase {
    intendedOrKnownLikelyDeath := FALSE,
    actualDifferentVictimDeath := TRUE,
    culpableHomicideCommitted := TRUE,
}

assert applies_s301(missing.intendedOrKnownLikelyDeath, missing.actualDifferentVictimDeath, missing.culpableHomicideCommitted) == FALSE
