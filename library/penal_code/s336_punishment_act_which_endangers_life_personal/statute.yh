/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr336-#pr336-

statute 336 "Punishment for act which endangers life or the personal safety of others" effective 1872-01-01 {
    elements {
        /// Section 336 requires doing an act, with either rashness or negligence, and the act must endanger human life or the personal safety of others.
        all_of {
            actus_reus doing_act := "Doing any act";
            any_of {
                mens_rea rash_act := "Doing the act so rashly";
                mens_rea negligent_act := "Doing the act so negligently";
            }
            any_of {
                circumstance endangers_human_life := "The act endangers human life";
                circumstance endangers_personal_safety_of_others := "The act endangers the personal safety of others";
            }
        }
    }

    penalty or_both when rash_act {
        imprisonment := 0 months .. 6 months;
        fine := $0.00 .. $2,500.00;
    }

    penalty or_both when negligent_act {
        imprisonment := 0 months .. 3 months;
        fine := $0.00 .. $1,500.00;
    }

    exception general_defence_s79 {
        "act done by reason of mistake of fact"
        "no s336 conviction per s79 general exception"
        when is_infringed(s79)
    }
    exception general_defence_s80 {
        "accident in the doing of a lawful act"
        "no s336 conviction per s80 general exception"
        when is_infringed(s80)
    }
    exception general_defence_s84 {
        "act done by a person of unsound mind"
        "no s336 conviction per s84 general exception"
        when is_infringed(s84)
    }
    exception general_defence_s96 {
        "act done in private defence"
        "no s336 conviction per s96 general exception"
        when is_infringed(s96)
    }
}
