// Test file for s336
// Yuho v5 Syntax

referencing penal_code/s336_punishment_act_which_endangers_life_personal

struct S336CaseTest {
    bool offenceCommitted,
}

S336CaseTest convicted := S336CaseTest {
    offenceCommitted := TRUE,
}

assert s336_applies(convicted.offenceCommitted) == TRUE

S336CaseTest acquitted := S336CaseTest {
    offenceCommitted := FALSE,
}

assert s336_applies(acquitted.offenceCommitted) == FALSE
