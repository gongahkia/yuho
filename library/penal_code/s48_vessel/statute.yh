// Singapore Penal Code Section 48 - "Vessel"
// Interpretation provision defining "vessel"

statute 48 "Vessel" effective 1872-01-01 {
    definitions {
        vessel := "Anything made for the conveyance by water of human beings, or of property";
    }
}
