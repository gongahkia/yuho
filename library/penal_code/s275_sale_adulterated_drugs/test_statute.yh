// Test file for s275
// Yuho v5 Syntax

referencing penal_code/s275_sale_adulterated_drugs

struct SaleAdulteratedTestCase { bool knew, bool sold, }
SaleAdulteratedTestCase good := SaleAdulteratedTestCase { knew := TRUE, sold := TRUE, }
assert is_offence(good.knew, good.sold) == TRUE
SaleAdulteratedTestCase innocent := SaleAdulteratedTestCase { knew := FALSE, sold := TRUE, }
assert is_offence(innocent.knew, innocent.sold) == FALSE
