// Test file for s404_dishonest_misappropriation_property
// Yuho v5 Syntax

referencing penal_code/s404_dishonest_misappropriation_property

struct S404TestCase {
    bool dishonestMisappropriation,
    bool knewPropertyInDeceasedPossessionAtDeath,
    bool notSincePossessedByEntitled,
}

S404TestCase servantCase := S404TestCase {
    dishonestMisappropriation := TRUE,
    knewPropertyInDeceasedPossessionAtDeath := TRUE,
    notSincePossessedByEntitled := TRUE,
}

assert s404_applies(servantCase.dishonestMisappropriation, servantCase.knewPropertyInDeceasedPossessionAtDeath, servantCase.notSincePossessedByEntitled) == TRUE

S404TestCase executorTook := S404TestCase {
    dishonestMisappropriation := TRUE,
    knewPropertyInDeceasedPossessionAtDeath := TRUE,
    notSincePossessedByEntitled := FALSE,
}

assert s404_applies(executorTook.dishonestMisappropriation, executorTook.knewPropertyInDeceasedPossessionAtDeath, executorTook.notSincePossessedByEntitled) == FALSE
