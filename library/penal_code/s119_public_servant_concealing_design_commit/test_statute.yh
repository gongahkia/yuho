// Test file for s119
// Yuho v5 Syntax

referencing penal_code/s119_public_servant_concealing_design_commit

struct S119Test {
    bool isPublicServant,
    bool intendsOrKnowsLikelyToFacilitate,
    bool dutyToPreventOffence,
    bool concealsOrMakesFalseRepresentation,
}

S119Test qualifying := S119Test {
    isPublicServant := TRUE,
    intendsOrKnowsLikelyToFacilitate := TRUE,
    dutyToPreventOffence := TRUE,
    concealsOrMakesFalseRepresentation := TRUE,
}
assert s119_applies(qualifying.isPublicServant, qualifying.intendsOrKnowsLikelyToFacilitate, qualifying.dutyToPreventOffence, qualifying.concealsOrMakesFalseRepresentation) == TRUE

S119Test notPublicServant := S119Test {
    isPublicServant := FALSE,
    intendsOrKnowsLikelyToFacilitate := TRUE,
    dutyToPreventOffence := TRUE,
    concealsOrMakesFalseRepresentation := TRUE,
}
assert s119_applies(notPublicServant.isPublicServant, notPublicServant.intendsOrKnowsLikelyToFacilitate, notPublicServant.dutyToPreventOffence, notPublicServant.concealsOrMakesFalseRepresentation) == FALSE
