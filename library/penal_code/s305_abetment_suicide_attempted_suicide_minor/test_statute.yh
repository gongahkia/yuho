// Test file for s305
// Yuho v5 Syntax

referencing penal_code/s305_abetment_suicide_attempted_suicide_minor

struct S305CaseTestCase {
    bool minorOrLacksCapacity,
    bool suicideOrAttempt,
    bool abetment,
    bool knowledgeOrReasonableKnowledge,
}

S305CaseTestCase matching := S305CaseTestCase {
    minorOrLacksCapacity := TRUE,
    suicideOrAttempt := TRUE,
    abetment := TRUE,
    knowledgeOrReasonableKnowledge := TRUE,
}

assert applies_s305(matching.minorOrLacksCapacity, matching.suicideOrAttempt, matching.abetment, matching.knowledgeOrReasonableKnowledge) == TRUE

S305CaseTestCase missing := S305CaseTestCase {
    minorOrLacksCapacity := FALSE,
    suicideOrAttempt := TRUE,
    abetment := TRUE,
    knowledgeOrReasonableKnowledge := TRUE,
}

assert applies_s305(missing.minorOrLacksCapacity, missing.suicideOrAttempt, missing.abetment, missing.knowledgeOrReasonableKnowledge) == FALSE
