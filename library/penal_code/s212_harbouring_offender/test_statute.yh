// Test file for s212_harbouring_offender
// Yuho v5 Syntax

referencing penal_code/s212_harbouring_offender

struct S212TestCase {
    bool offenceCommitted,
    bool harboursOrConceals,
    bool knowsOrReasonToBelieveOffender,
    bool intentionToScreenOffender,
    string underlyingOffencePunishment,
}

S212TestCase harbourMurderer := S212TestCase {
    offenceCommitted := TRUE,
    harboursOrConceals := TRUE,
    knowsOrReasonToBelieveOffender := TRUE,
    intentionToScreenOffender := TRUE,
    underlyingOffencePunishment := "death",
}

assert evaluate_s212(harbourMurderer.offenceCommitted, harbourMurderer.harboursOrConceals, harbourMurderer.knowsOrReasonToBelieveOffender, harbourMurderer.intentionToScreenOffender, harbourMurderer.underlyingOffencePunishment) == "Liable s212(1)(a) - up to 10 years + fine"

S212TestCase harbourLesser := S212TestCase {
    offenceCommitted := TRUE,
    harboursOrConceals := TRUE,
    knowsOrReasonToBelieveOffender := TRUE,
    intentionToScreenOffender := TRUE,
    underlyingOffencePunishment := "short_term",
}

assert evaluate_s212(harbourLesser.offenceCommitted, harbourLesser.harboursOrConceals, harbourLesser.knowsOrReasonToBelieveOffender, harbourLesser.intentionToScreenOffender, harbourLesser.underlyingOffencePunishment) == "Liable s212(1)(c) - up to 1/4 of longest term"

S212TestCase noScreeningIntent := S212TestCase {
    offenceCommitted := TRUE,
    harboursOrConceals := TRUE,
    knowsOrReasonToBelieveOffender := TRUE,
    intentionToScreenOffender := FALSE,
    underlyingOffencePunishment := "death",
}

assert evaluate_s212(noScreeningIntent.offenceCommitted, noScreeningIntent.harboursOrConceals, noScreeningIntent.knowsOrReasonToBelieveOffender, noScreeningIntent.intentionToScreenOffender, noScreeningIntent.underlyingOffencePunishment) == "Not liable - no screening intent"
