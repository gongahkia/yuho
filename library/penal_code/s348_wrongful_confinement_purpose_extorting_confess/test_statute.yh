// Test file for s348
// Yuho v5 Syntax

referencing penal_code/s348_wrongful_confinement_purpose_extorting_confess

struct S348CaseTest {
    bool actusReus,
    bool mensRea,
}

S348CaseTest satisfied := S348CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s348_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S348CaseTest missingMens := S348CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s348_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
