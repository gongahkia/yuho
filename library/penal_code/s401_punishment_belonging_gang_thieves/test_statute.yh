// Test file for s401_punishment_belonging_gang_thieves
// Yuho v5 Syntax

referencing penal_code/s401_punishment_belonging_gang_thieves

struct S401TestCase {
    bool belongsToGang,
    bool gangHabituallyCommitsTheftOrRobbery,
    bool notGangRobbers,
}

S401TestCase member := S401TestCase {
    belongsToGang := TRUE,
    gangHabituallyCommitsTheftOrRobbery := TRUE,
    notGangRobbers := TRUE,
}

assert s401_applies(member.belongsToGang, member.gangHabituallyCommitsTheftOrRobbery, member.notGangRobbers) == TRUE

S401TestCase outsider := S401TestCase {
    belongsToGang := FALSE,
    gangHabituallyCommitsTheftOrRobbery := TRUE,
    notGangRobbers := TRUE,
}

assert s401_applies(outsider.belongsToGang, outsider.gangHabituallyCommitsTheftOrRobbery, outsider.notGangRobbers) == FALSE
