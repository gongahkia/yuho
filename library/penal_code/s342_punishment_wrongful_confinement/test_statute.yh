// Test file for s342
// Yuho v5 Syntax

referencing penal_code/s342_punishment_wrongful_confinement

struct S342CaseTest {
    bool offenceCommitted,
}

S342CaseTest convicted := S342CaseTest {
    offenceCommitted := TRUE,
}

assert s342_applies(convicted.offenceCommitted) == TRUE

S342CaseTest acquitted := S342CaseTest {
    offenceCommitted := FALSE,
}

assert s342_applies(acquitted.offenceCommitted) == FALSE
