// Test file for s201_causing_disappearance_evidence_offence

referencing penal_code/s201_causing_disappearance_evidence_offence

struct CausingDisappearanceEvidenceOffenceTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CausingDisappearanceEvidenceOffenceTestCase guilty := CausingDisappearanceEvidenceOffenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_causing_disappearance_evidence_offence(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CausingDisappearanceEvidenceOffenceTestCase defended := CausingDisappearanceEvidenceOffenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_causing_disappearance_evidence_offence(defended.elements_satisfied, defended.defence_applies) == FALSE

CausingDisappearanceEvidenceOffenceTestCase notMadeOut := CausingDisappearanceEvidenceOffenceTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_causing_disappearance_evidence_offence(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
