// Test file for s122_collecting_arms_etc_intention_waging_war

referencing penal_code/s122_collecting_arms_etc_intention_waging_war

struct CollectingArmsEtcIntentionTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

CollectingArmsEtcIntentionTestCase guilty := CollectingArmsEtcIntentionTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_collecting_arms_etc_intention(guilty.elements_satisfied, guilty.defence_applies) == TRUE

CollectingArmsEtcIntentionTestCase defended := CollectingArmsEtcIntentionTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_collecting_arms_etc_intention(defended.elements_satisfied, defended.defence_applies) == FALSE

CollectingArmsEtcIntentionTestCase notMadeOut := CollectingArmsEtcIntentionTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_collecting_arms_etc_intention(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
