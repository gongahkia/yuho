// Test file for s120
// Yuho v5 Syntax

referencing penal_code/s120_concealing_design_commit_offence_punishable

struct S120Test {
    bool intendsOrKnowsLikelyToFacilitate,
    bool offencePunishableByImprisonment,
    bool concealsOrMakesFalseRepresentation,
}

S120Test qualifying := S120Test {
    intendsOrKnowsLikelyToFacilitate := TRUE,
    offencePunishableByImprisonment := TRUE,
    concealsOrMakesFalseRepresentation := TRUE,
}
assert s120_applies(qualifying.intendsOrKnowsLikelyToFacilitate, qualifying.offencePunishableByImprisonment, qualifying.concealsOrMakesFalseRepresentation) == TRUE

S120Test noConcealment := S120Test {
    intendsOrKnowsLikelyToFacilitate := TRUE,
    offencePunishableByImprisonment := TRUE,
    concealsOrMakesFalseRepresentation := FALSE,
}
assert s120_applies(noConcealment.intendsOrKnowsLikelyToFacilitate, noConcealment.offencePunishableByImprisonment, noConcealment.concealsOrMakesFalseRepresentation) == FALSE
