// Test file for s118
// Yuho v5 Syntax

referencing penal_code/s118_concealing_design_commit_offence_punishable

struct S118Test {
    bool intendsOrKnowsLikelyToFacilitate,
    bool offencePunishableByDeathOrLife,
    bool concealsOrMakesFalseRepresentation,
}

S118Test qualifying := S118Test {
    intendsOrKnowsLikelyToFacilitate := TRUE,
    offencePunishableByDeathOrLife := TRUE,
    concealsOrMakesFalseRepresentation := TRUE,
}
assert s118_applies(qualifying.intendsOrKnowsLikelyToFacilitate, qualifying.offencePunishableByDeathOrLife, qualifying.concealsOrMakesFalseRepresentation) == TRUE

S118Test lesserOffence := S118Test {
    intendsOrKnowsLikelyToFacilitate := TRUE,
    offencePunishableByDeathOrLife := FALSE,
    concealsOrMakesFalseRepresentation := TRUE,
}
assert s118_applies(lesserOffence.intendsOrKnowsLikelyToFacilitate, lesserOffence.offencePunishableByDeathOrLife, lesserOffence.concealsOrMakesFalseRepresentation) == FALSE
