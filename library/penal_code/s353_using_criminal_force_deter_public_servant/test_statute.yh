// Test file for s353
// Yuho v5 Syntax

referencing penal_code/s353_using_criminal_force_deter_public_servant

struct S353CaseTest {
    bool offenceCommitted,
}

S353CaseTest convicted := S353CaseTest {
    offenceCommitted := TRUE,
}

assert s353_applies(convicted.offenceCommitted) == TRUE

S353CaseTest acquitted := S353CaseTest {
    offenceCommitted := FALSE,
}

assert s353_applies(acquitted.offenceCommitted) == FALSE
