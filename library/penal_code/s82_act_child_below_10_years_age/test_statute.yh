// test file for s82 - doli incapax (under 10)
referencing penal_code/s82_act_child_below_10_years_age

struct ChildTest {
    int age,
}

ChildTest eightYearOld := ChildTest { age := 8 }
assert child_under_10_defence(eightYearOld.age) == TRUE

ChildTest tenYearOld := ChildTest { age := 10 }
assert child_under_10_defence(tenYearOld.age) == FALSE

ChildTest teenager := ChildTest { age := 15 }
assert child_under_10_defence(teenager.age) == FALSE
