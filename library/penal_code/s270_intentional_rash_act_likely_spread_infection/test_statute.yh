// Test file for s270_intentional_rash_act_likely_spread_infection

referencing penal_code/s270_intentional_rash_act_likely_spread_infection

struct IntentionalRashActLikelyTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

IntentionalRashActLikelyTestCase guilty := IntentionalRashActLikelyTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_intentional_rash_act_likely(guilty.elements_satisfied, guilty.defence_applies) == TRUE

IntentionalRashActLikelyTestCase defended := IntentionalRashActLikelyTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_intentional_rash_act_likely(defended.elements_satisfied, defended.defence_applies) == FALSE

IntentionalRashActLikelyTestCase notMadeOut := IntentionalRashActLikelyTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_intentional_rash_act_likely(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
