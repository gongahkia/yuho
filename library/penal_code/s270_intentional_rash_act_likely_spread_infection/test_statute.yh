// Test file for s270
// Yuho v5 Syntax

referencing penal_code/s270_intentional_rash_act_likely_spread_infection

struct IntentionalInfectionTestCase {
    bool actDone,
    bool intentionalOrRash,
    bool knowledgeOrReasonToBelieve,
    bool likelyToSpreadInfection,
    bool diseaseDangerousToLife,
}

IntentionalInfectionTestCase allElements := IntentionalInfectionTestCase {
    actDone := TRUE,
    intentionalOrRash := TRUE,
    knowledgeOrReasonToBelieve := TRUE,
    likelyToSpreadInfection := TRUE,
    diseaseDangerousToLife := TRUE,
}
assert is_offence(allElements.actDone, allElements.intentionalOrRash, allElements.knowledgeOrReasonToBelieve, allElements.likelyToSpreadInfection, allElements.diseaseDangerousToLife) == TRUE

IntentionalInfectionTestCase notDangerous := IntentionalInfectionTestCase {
    actDone := TRUE,
    intentionalOrRash := TRUE,
    knowledgeOrReasonToBelieve := TRUE,
    likelyToSpreadInfection := TRUE,
    diseaseDangerousToLife := FALSE,
}
assert is_offence(notDangerous.actDone, notDangerous.intentionalOrRash, notDangerous.knowledgeOrReasonToBelieve, notDangerous.likelyToSpreadInfection, notDangerous.diseaseDangerousToLife) == FALSE
