// Test file for s425_mischief

referencing penal_code/s425_mischief

struct MischiefTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

MischiefTestCase guilty := MischiefTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_mischief(guilty.elements_satisfied, guilty.defence_applies) == TRUE

MischiefTestCase defended := MischiefTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_mischief(defended.elements_satisfied, defended.defence_applies) == FALSE

MischiefTestCase notMadeOut := MischiefTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_mischief(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
