// Test file for s314
// Yuho v5 Syntax

referencing penal_code/s314_death_caused_act_done_intent_cause

struct S314CaseTest {
    bool actusReus,
    bool mensRea,
}

S314CaseTest satisfied := S314CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s314_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S314CaseTest missingMens := S314CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s314_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
