// Test file for s334
// Yuho v5 Syntax

referencing penal_code/s334_voluntarily_causing_hurt_provocation

struct S334CaseTest {
    bool actusReus,
    bool mensRea,
}

S334CaseTest satisfied := S334CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s334_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S334CaseTest missingMens := S334CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s334_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
