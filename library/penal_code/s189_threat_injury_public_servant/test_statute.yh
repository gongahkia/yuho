// Test file for s189_threat_injury_public_servant

referencing penal_code/s189_threat_injury_public_servant

struct ThreatInjuryPublicServantTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

ThreatInjuryPublicServantTestCase guilty := ThreatInjuryPublicServantTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_threat_injury_public_servant(guilty.elements_satisfied, guilty.defence_applies) == TRUE

ThreatInjuryPublicServantTestCase defended := ThreatInjuryPublicServantTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_threat_injury_public_servant(defended.elements_satisfied, defended.defence_applies) == FALSE

ThreatInjuryPublicServantTestCase notMadeOut := ThreatInjuryPublicServantTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_threat_injury_public_servant(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
