// Test file for s189_threat_injury_public_servant
// Yuho v5 Syntax

referencing penal_code/s189_threat_injury_public_servant

struct S189TestCase {
    bool holdsOutThreat,
    bool targetIsPublicServantOrInterested,
    bool purposeToInducePublicFunction,
}

S189TestCase coerceOfficer := S189TestCase {
    holdsOutThreat := TRUE,
    targetIsPublicServantOrInterested := TRUE,
    purposeToInducePublicFunction := TRUE,
}

assert evaluate_s189(coerceOfficer.holdsOutThreat, coerceOfficer.targetIsPublicServantOrInterested, coerceOfficer.purposeToInducePublicFunction) == "Liable under s189"

S189TestCase wrongTarget := S189TestCase {
    holdsOutThreat := TRUE,
    targetIsPublicServantOrInterested := FALSE,
    purposeToInducePublicFunction := TRUE,
}

assert evaluate_s189(wrongTarget.holdsOutThreat, wrongTarget.targetIsPublicServantOrInterested, wrongTarget.purposeToInducePublicFunction) == "Not liable - target not public servant or associate"

S189TestCase noThreat := S189TestCase {
    holdsOutThreat := FALSE,
    targetIsPublicServantOrInterested := TRUE,
    purposeToInducePublicFunction := TRUE,
}

assert evaluate_s189(noThreat.holdsOutThreat, noThreat.targetIsPublicServantOrInterested, noThreat.purposeToInducePublicFunction) == "Not liable - no threat"
