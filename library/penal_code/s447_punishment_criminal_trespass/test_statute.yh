// Test file for s447_punishment_criminal_trespass

referencing penal_code/s447_punishment_criminal_trespass

struct PunishmentCriminalTrespassTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

PunishmentCriminalTrespassTestCase guilty := PunishmentCriminalTrespassTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_punishment_criminal_trespass(guilty.elements_satisfied, guilty.defence_applies) == TRUE

PunishmentCriminalTrespassTestCase defended := PunishmentCriminalTrespassTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_punishment_criminal_trespass(defended.elements_satisfied, defended.defence_applies) == FALSE

PunishmentCriminalTrespassTestCase notMadeOut := PunishmentCriminalTrespassTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_punishment_criminal_trespass(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
