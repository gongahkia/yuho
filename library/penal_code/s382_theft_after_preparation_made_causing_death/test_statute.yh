// Test file for s382_theft_after_preparation_made_causing_death
// Yuho v5 Syntax

referencing penal_code/s382_theft_after_preparation_made_causing_death

struct S382TestCase {
    bool theftCommitted,
    bool preparationMade,
}

S382TestCase armedTheft := S382TestCase {
    theftCommitted := TRUE,
    preparationMade := TRUE,
}

assert s382_applies(armedTheft.theftCommitted, armedTheft.preparationMade) == TRUE

S382TestCase plainTheft := S382TestCase {
    theftCommitted := TRUE,
    preparationMade := FALSE,
}

assert s382_applies(plainTheft.theftCommitted, plainTheft.preparationMade) == FALSE
