// Singapore Penal Code Section 8 - "Gender"
// Shape: interpretation / definition

statute 8 "Gender" effective 1872-01-01 {
    definitions {
        he_pronoun_rule := "The pronoun he and its derivatives are used of any person, whether male or female";
    }
}
