// Test file for s489G_altering_appearance_currency_intent_that_it
// Yuho v5 Syntax

referencing penal_code/s489G_altering_appearance_currency_intent_that_it

struct AlteringAppearanceCurrencyCaseTest {
    bool elementsSatisfied,
}

AlteringAppearanceCurrencyCaseTest positive := AlteringAppearanceCurrencyCaseTest {
    elementsSatisfied := TRUE,
}

assert positive.elementsSatisfied == TRUE
assert is_liable(positive.elementsSatisfied) == TRUE

AlteringAppearanceCurrencyCaseTest negative := AlteringAppearanceCurrencyCaseTest {
    elementsSatisfied := FALSE,
}

assert negative.elementsSatisfied == FALSE
assert is_liable(negative.elementsSatisfied) == FALSE
