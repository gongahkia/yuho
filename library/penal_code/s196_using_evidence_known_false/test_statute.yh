// Test file for s196_using_evidence_known_false
// Yuho v5 Syntax

referencing penal_code/s196_using_evidence_known_false

struct S196TestCase {
    bool corruptlyUsesAsTrue,
    bool knowsEvidenceFalse,
}

S196TestCase usingForged := S196TestCase {
    corruptlyUsesAsTrue := TRUE,
    knowsEvidenceFalse := TRUE,
}

assert evaluate_s196(usingForged.corruptlyUsesAsTrue, usingForged.knowsEvidenceFalse) == "Liable under s196"

S196TestCase unknowinglyUsed := S196TestCase {
    corruptlyUsesAsTrue := TRUE,
    knowsEvidenceFalse := FALSE,
}

assert evaluate_s196(unknowinglyUsed.corruptlyUsesAsTrue, unknowinglyUsed.knowsEvidenceFalse) == "Not liable - no knowledge of falsity"
