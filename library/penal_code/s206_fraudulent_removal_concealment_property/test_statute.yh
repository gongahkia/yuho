// Test file for s206_fraudulent_removal_concealment_property
// Yuho v5 Syntax

referencing penal_code/s206_fraudulent_removal_concealment_property

struct S206TestCase {
    bool fraudulentlyRemovesConceals,
    bool intentToPreventSeizure,
    bool propertySubjectToForfeitureOrExecution,
}

S206TestCase hidingAssets := S206TestCase {
    fraudulentlyRemovesConceals := TRUE,
    intentToPreventSeizure := TRUE,
    propertySubjectToForfeitureOrExecution := TRUE,
}

assert evaluate_s206(hidingAssets.fraudulentlyRemovesConceals, hidingAssets.intentToPreventSeizure, hidingAssets.propertySubjectToForfeitureOrExecution) == "Liable under s206"

S206TestCase legitimateTransfer := S206TestCase {
    fraudulentlyRemovesConceals := FALSE,
    intentToPreventSeizure := FALSE,
    propertySubjectToForfeitureOrExecution := TRUE,
}

assert evaluate_s206(legitimateTransfer.fraudulentlyRemovesConceals, legitimateTransfer.intentToPreventSeizure, legitimateTransfer.propertySubjectToForfeitureOrExecution) == "Not liable - no fraudulent removal or concealment"
