// Test file for s307_attempt_murder

referencing penal_code/s307_attempt_murder

struct AttemptMurderTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

AttemptMurderTestCase guilty := AttemptMurderTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_attempt_murder(guilty.elements_satisfied, guilty.defence_applies) == TRUE

AttemptMurderTestCase defended := AttemptMurderTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_attempt_murder(defended.elements_satisfied, defended.defence_applies) == FALSE

AttemptMurderTestCase notMadeOut := AttemptMurderTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_attempt_murder(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
