// Test file for s310
// Yuho v5 Syntax

referencing penal_code/s310_infanticide

struct S310CaseTestCase {
    bool womanCausesChildDeath,
    bool childBelowTwelveMonths,
    bool intentionalActOrOmission,
    bool disturbedBalanceOfMind,
}

S310CaseTestCase matching := S310CaseTestCase {
    womanCausesChildDeath := TRUE,
    childBelowTwelveMonths := TRUE,
    intentionalActOrOmission := TRUE,
    disturbedBalanceOfMind := TRUE,
}

assert applies_s310(matching.womanCausesChildDeath, matching.childBelowTwelveMonths, matching.intentionalActOrOmission, matching.disturbedBalanceOfMind) == TRUE

S310CaseTestCase missing := S310CaseTestCase {
    womanCausesChildDeath := FALSE,
    childBelowTwelveMonths := TRUE,
    intentionalActOrOmission := TRUE,
    disturbedBalanceOfMind := TRUE,
}

assert applies_s310(missing.womanCausesChildDeath, missing.childBelowTwelveMonths, missing.intentionalActOrOmission, missing.disturbedBalanceOfMind) == FALSE
