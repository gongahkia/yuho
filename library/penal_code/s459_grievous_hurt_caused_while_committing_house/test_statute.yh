// Test file for s459_grievous_hurt_caused_while_committing_house

referencing penal_code/s459_grievous_hurt_caused_while_committing_house

struct GrievousHurtDuringHouseBreakingTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

GrievousHurtDuringHouseBreakingTestCase guilty := GrievousHurtDuringHouseBreakingTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_grievous_hurt_during_house_breaking(guilty.elements_satisfied, guilty.defence_applies) == TRUE

GrievousHurtDuringHouseBreakingTestCase defended := GrievousHurtDuringHouseBreakingTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_grievous_hurt_during_house_breaking(defended.elements_satisfied, defended.defence_applies) == FALSE

GrievousHurtDuringHouseBreakingTestCase notMadeOut := GrievousHurtDuringHouseBreakingTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_grievous_hurt_during_house_breaking(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
