// Test file for s107_abetment_doing_thing

referencing penal_code/s107_abetment_doing_thing

struct AbetmentDoingThingTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

AbetmentDoingThingTestCase guilty := AbetmentDoingThingTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_abetment_doing_thing(guilty.elements_satisfied, guilty.defence_applies) == TRUE

AbetmentDoingThingTestCase defended := AbetmentDoingThingTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_abetment_doing_thing(defended.elements_satisfied, defended.defence_applies) == FALSE

AbetmentDoingThingTestCase notMadeOut := AbetmentDoingThingTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_abetment_doing_thing(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
