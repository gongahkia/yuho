// Test file for s193_punishment_false_evidence

referencing penal_code/s193_punishment_false_evidence

struct PunishmentFalseEvidenceTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

PunishmentFalseEvidenceTestCase guilty := PunishmentFalseEvidenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_punishment_false_evidence(guilty.elements_satisfied, guilty.defence_applies) == TRUE

PunishmentFalseEvidenceTestCase defended := PunishmentFalseEvidenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_punishment_false_evidence(defended.elements_satisfied, defended.defence_applies) == FALSE

PunishmentFalseEvidenceTestCase notMadeOut := PunishmentFalseEvidenceTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_punishment_false_evidence(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
