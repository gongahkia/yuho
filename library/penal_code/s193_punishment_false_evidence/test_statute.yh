// Test file for s193_punishment_false_evidence
// Yuho v5 Syntax

referencing penal_code/s193_punishment_false_evidence

struct S193TestCase {
    bool intentionallyGivesFalseEvidence,
    bool fabricatesForJudicial,
    bool inJudicialProceeding,
}

S193TestCase perjuryInCourt := S193TestCase {
    intentionallyGivesFalseEvidence := TRUE,
    fabricatesForJudicial := FALSE,
    inJudicialProceeding := TRUE,
}

assert evaluate_s193(perjuryInCourt.intentionallyGivesFalseEvidence, perjuryInCourt.fabricatesForJudicial, perjuryInCourt.inJudicialProceeding) == "Liable - up to 7 years (judicial)"

S193TestCase nonJudicialLie := S193TestCase {
    intentionallyGivesFalseEvidence := TRUE,
    fabricatesForJudicial := FALSE,
    inJudicialProceeding := FALSE,
}

assert evaluate_s193(nonJudicialLie.intentionallyGivesFalseEvidence, nonJudicialLie.fabricatesForJudicial, nonJudicialLie.inJudicialProceeding) == "Liable - up to 3 years (non-judicial)"

S193TestCase notDone := S193TestCase {
    intentionallyGivesFalseEvidence := FALSE,
    fabricatesForJudicial := FALSE,
    inJudicialProceeding := TRUE,
}

assert evaluate_s193(notDone.intentionallyGivesFalseEvidence, notDone.fabricatesForJudicial, notDone.inJudicialProceeding) == "Not liable - neither giving nor fabricating"
