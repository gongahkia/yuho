// Test file for s188_disobedience_order_duly_promulgated_public

referencing penal_code/s188_disobedience_order_duly_promulgated_public

struct DisobedienceOrderDulyPromulgatedTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

DisobedienceOrderDulyPromulgatedTestCase guilty := DisobedienceOrderDulyPromulgatedTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_disobedience_order_duly_promulgated(guilty.elements_satisfied, guilty.defence_applies) == TRUE

DisobedienceOrderDulyPromulgatedTestCase defended := DisobedienceOrderDulyPromulgatedTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_disobedience_order_duly_promulgated(defended.elements_satisfied, defended.defence_applies) == FALSE

DisobedienceOrderDulyPromulgatedTestCase notMadeOut := DisobedienceOrderDulyPromulgatedTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_disobedience_order_duly_promulgated(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
