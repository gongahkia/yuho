// Test file for s77_act_judge_when_acting_judicially
// Yuho v5 Syntax

referencing penal_code/s77_act_judge_when_acting_judicially

struct JudgeTestCase {
    bool actingJudicially,
    bool powerGivenByLaw,
    bool goodFaithBelief,
}

// judge with actual power: defence applies
JudgeTestCase withPower := JudgeTestCase {
    actingJudicially := TRUE,
    powerGivenByLaw := TRUE,
    goodFaithBelief := TRUE,
}

assert judge_defence_applies(withPower.actingJudicially, withPower.powerGivenByLaw, withPower.goodFaithBelief) == TRUE

// judge with only good faith belief: defence applies
JudgeTestCase goodFaithOnly := JudgeTestCase {
    actingJudicially := TRUE,
    powerGivenByLaw := FALSE,
    goodFaithBelief := TRUE,
}

assert judge_defence_applies(goodFaithOnly.actingJudicially, goodFaithOnly.powerGivenByLaw, goodFaithOnly.goodFaithBelief) == TRUE

// judge not acting judicially: defence fails
JudgeTestCase notJudicial := JudgeTestCase {
    actingJudicially := FALSE,
    powerGivenByLaw := TRUE,
    goodFaithBelief := TRUE,
}

assert judge_defence_applies(notJudicial.actingJudicially, notJudicial.powerGivenByLaw, notJudicial.goodFaithBelief) == FALSE
