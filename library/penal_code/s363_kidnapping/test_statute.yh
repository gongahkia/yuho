// Test file for s363_kidnapping

referencing penal_code/s363_kidnapping


struct S363TestCase {
    string kidnappingType,
    bool conveyedFromSingapore,
    bool takenFromLawfulGuardian,
}


S363TestCase fromSG := S363TestCase {
    kidnappingType := "from_singapore",
    conveyedFromSingapore := TRUE,
    takenFromLawfulGuardian := FALSE,
}

assert is_kidnapping(fromSG.kidnappingType, fromSG.conveyedFromSingapore, fromSG.takenFromLawfulGuardian) == TRUE


S363TestCase fromGuardian := S363TestCase {
    kidnappingType := "from_lawful_guardianship",
    conveyedFromSingapore := FALSE,
    takenFromLawfulGuardian := TRUE,
}

assert is_kidnapping(fromGuardian.kidnappingType, fromGuardian.conveyedFromSingapore, fromGuardian.takenFromLawfulGuardian) == TRUE


S363TestCase notConveyed := S363TestCase {
    kidnappingType := "from_singapore",
    conveyedFromSingapore := FALSE,
    takenFromLawfulGuardian := FALSE,
}

assert is_kidnapping(notConveyed.kidnappingType, notConveyed.conveyedFromSingapore, notConveyed.takenFromLawfulGuardian) == FALSE


S363TestCase unknownType := S363TestCase {
    kidnappingType := "none",
    conveyedFromSingapore := TRUE,
    takenFromLawfulGuardian := TRUE,
}

assert is_kidnapping(unknownType.kidnappingType, unknownType.conveyedFromSingapore, unknownType.takenFromLawfulGuardian) == FALSE
