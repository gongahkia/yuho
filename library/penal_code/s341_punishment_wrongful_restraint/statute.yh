/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr341-#pr341-

referencing penal_code/s339_wrongful_restraint

statute 341 "Punishment for wrongful restraint" effective 1872-01-01 {
    /// Punishment for the offence of wrongful restraint under section 339.
    penalty or_both {
        imprisonment := 0 days .. 1 month;
        fine := $0.00 .. $1,500.00;
    }
}
