// Test file for s341
// Yuho v5 Syntax

referencing penal_code/s341_punishment_wrongful_restraint

struct S341CaseTest {
    bool offenceCommitted,
}

S341CaseTest convicted := S341CaseTest {
    offenceCommitted := TRUE,
}

assert s341_applies(convicted.offenceCommitted) == TRUE

S341CaseTest acquitted := S341CaseTest {
    offenceCommitted := FALSE,
}

assert s341_applies(acquitted.offenceCommitted) == FALSE
