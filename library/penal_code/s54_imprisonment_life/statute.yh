/// @jurisdiction singapore
/// @meta act=Penal Code 1871
/// @meta source=https://sso.agc.gov.sg/Act/PC1871?ProvIds=pr54-#pr54-

statute 54 "Imprisonment for life" effective 1872-01-01 {
    definitions {
        imprisonment_for_life := "“Imprisonment for life”, in relation to any prescribed punishment under this Code or any other written law, means imprisonment for the duration of a person’s natural life.";
    }
}
