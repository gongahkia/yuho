// Test file for s315
// Yuho v5 Syntax

referencing penal_code/s315_child_destruction_before_immediately_after

struct S315CaseTest {
    bool actusReus,
    bool mensRea,
}

S315CaseTest satisfied := S315CaseTest {
    actusReus := TRUE,
    mensRea := TRUE,
}

assert s315_applies(satisfied.actusReus, satisfied.mensRea) == TRUE

S315CaseTest missingMens := S315CaseTest {
    actusReus := TRUE,
    mensRea := FALSE,
}

assert s315_applies(missingMens.actusReus, missingMens.mensRea) == FALSE
