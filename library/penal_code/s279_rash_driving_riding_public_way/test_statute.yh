// Test file for s279
// Yuho v5 Syntax

referencing penal_code/s279_rash_driving_riding_public_way

struct RashDrivingTestCase { bool drove, bool publicWay, bool rash, bool endanger, }
RashDrivingTestCase good := RashDrivingTestCase { drove := TRUE, publicWay := TRUE, rash := TRUE, endanger := TRUE, }
assert is_offence(good.drove, good.publicWay, good.rash, good.endanger) == TRUE
RashDrivingTestCase safeRoad := RashDrivingTestCase { drove := TRUE, publicWay := TRUE, rash := FALSE, endanger := FALSE, }
assert is_offence(safeRoad.drove, safeRoad.publicWay, safeRoad.rash, safeRoad.endanger) == FALSE
