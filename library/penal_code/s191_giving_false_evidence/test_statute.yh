// Test file for s191_giving_false_evidence
// Yuho v5 Syntax

referencing penal_code/s191_giving_false_evidence

struct S191TestCase {
    bool legallyBound,
    bool statementMade,
    bool statementFalse,
    bool knowsOrBelievesFalse,
}

S191TestCase perjury := S191TestCase {
    legallyBound := TRUE,
    statementMade := TRUE,
    statementFalse := TRUE,
    knowsOrBelievesFalse := TRUE,
}

assert evaluate_s191(perjury.legallyBound, perjury.statementMade, perjury.statementFalse, perjury.knowsOrBelievesFalse) == "Said to give false evidence"

S191TestCase honestMistake := S191TestCase {
    legallyBound := TRUE,
    statementMade := TRUE,
    statementFalse := TRUE,
    knowsOrBelievesFalse := FALSE,
}

assert evaluate_s191(honestMistake.legallyBound, honestMistake.statementMade, honestMistake.statementFalse, honestMistake.knowsOrBelievesFalse) == "Not false evidence - no knowledge of falsity"

S191TestCase notUnderOath := S191TestCase {
    legallyBound := FALSE,
    statementMade := TRUE,
    statementFalse := TRUE,
    knowsOrBelievesFalse := TRUE,
}

assert evaluate_s191(notUnderOath.legallyBound, notUnderOath.statementMade, notUnderOath.statementFalse, notUnderOath.knowsOrBelievesFalse) == "Not false evidence - not legally bound"
