// Test file for s191_giving_false_evidence

referencing penal_code/s191_giving_false_evidence

struct GivingFalseEvidenceTestCase {
    bool elements_satisfied,
    bool defence_applies,
}

GivingFalseEvidenceTestCase guilty := GivingFalseEvidenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := FALSE,
}
assert is_giving_false_evidence(guilty.elements_satisfied, guilty.defence_applies) == TRUE

GivingFalseEvidenceTestCase defended := GivingFalseEvidenceTestCase {
    elements_satisfied := TRUE,
    defence_applies := TRUE,
}
assert is_giving_false_evidence(defended.elements_satisfied, defended.defence_applies) == FALSE

GivingFalseEvidenceTestCase notMadeOut := GivingFalseEvidenceTestCase {
    elements_satisfied := FALSE,
    defence_applies := FALSE,
}
assert is_giving_false_evidence(notMadeOut.elements_satisfied, notMadeOut.defence_applies) == FALSE
