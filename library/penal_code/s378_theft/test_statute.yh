// Test file for s378_theft

referencing penal_code/s378_theft


struct TheftTestCase {
    string propertyType,
    string dishonestIntention,
    bool consent,
    bool inPossessionOfAnother,
    bool propertyMoved,
}


TheftTestCase normalTheft := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    consent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert normalTheft.propertyType == "movable_property"
assert normalTheft.dishonestIntention == "wrongful_gain"
assert normalTheft.consent == FALSE
assert normalTheft.inPossessionOfAnother == TRUE
assert normalTheft.propertyMoved == TRUE
assert is_theft(normalTheft.propertyType, normalTheft.dishonestIntention, normalTheft.consent, normalTheft.inPossessionOfAnother, normalTheft.propertyMoved) == TRUE


TheftTestCase wrongfulLossTheft := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_loss",
    consent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert wrongfulLossTheft.dishonestIntention == "wrongful_loss"
assert is_theft(wrongfulLossTheft.propertyType, wrongfulLossTheft.dishonestIntention, wrongfulLossTheft.consent, wrongfulLossTheft.inPossessionOfAnother, wrongfulLossTheft.propertyMoved) == TRUE


TheftTestCase noProperty := TheftTestCase {
    propertyType := "none",
    dishonestIntention := "wrongful_gain",
    consent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert noProperty.propertyType == "none"
assert is_theft(noProperty.propertyType, noProperty.dishonestIntention, noProperty.consent, noProperty.inPossessionOfAnother, noProperty.propertyMoved) == FALSE


TheftTestCase noIntention := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "none",
    consent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert noIntention.dishonestIntention == "none"
assert is_theft(noIntention.propertyType, noIntention.dishonestIntention, noIntention.consent, noIntention.inPossessionOfAnother, noIntention.propertyMoved) == FALSE


TheftTestCase withConsent := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    consent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert withConsent.consent == TRUE
assert is_theft(withConsent.propertyType, withConsent.dishonestIntention, withConsent.consent, withConsent.inPossessionOfAnother, withConsent.propertyMoved) == FALSE


TheftTestCase notInPossession := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    consent := FALSE,
    inPossessionOfAnother := FALSE,
    propertyMoved := TRUE,
}

assert notInPossession.inPossessionOfAnother == FALSE
assert is_theft(notInPossession.propertyType, notInPossession.dishonestIntention, notInPossession.consent, notInPossession.inPossessionOfAnother, notInPossession.propertyMoved) == FALSE


TheftTestCase notMoved := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    consent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := FALSE,
}

assert notMoved.propertyMoved == FALSE
assert is_theft(notMoved.propertyType, notMoved.dishonestIntention, notMoved.consent, notMoved.inPossessionOfAnother, notMoved.propertyMoved) == FALSE
