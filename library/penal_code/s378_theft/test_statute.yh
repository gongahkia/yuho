// Test file for s378_theft
// Yuho v5 Syntax

referencing penal_code/s378_theft

// ----- test structs -----

struct TheftTestCase {
    string propertyType,
    string dishonestIntention,
    bool withoutConsent,
    bool inPossessionOfAnother,
    bool propertyMoved,
}

// ----- normal theft: all elements present -----

TheftTestCase normalTheft := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    withoutConsent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert normalTheft.propertyType == "movable_property"
assert normalTheft.dishonestIntention == "wrongful_gain"
assert normalTheft.withoutConsent == TRUE
assert normalTheft.inPossessionOfAnother == TRUE
assert normalTheft.propertyMoved == TRUE
assert is_theft(normalTheft.propertyType, normalTheft.dishonestIntention, normalTheft.withoutConsent, normalTheft.inPossessionOfAnother, normalTheft.propertyMoved) == TRUE

// ----- wrongful loss intention -----

TheftTestCase wrongfulLossTheft := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_loss",
    withoutConsent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert wrongfulLossTheft.dishonestIntention == "wrongful_loss"
assert is_theft(wrongfulLossTheft.propertyType, wrongfulLossTheft.dishonestIntention, wrongfulLossTheft.withoutConsent, wrongfulLossTheft.inPossessionOfAnother, wrongfulLossTheft.propertyMoved) == TRUE

// ----- no property: not theft -----

TheftTestCase noProperty := TheftTestCase {
    propertyType := "none",
    dishonestIntention := "wrongful_gain",
    withoutConsent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert noProperty.propertyType == "none"
assert is_theft(noProperty.propertyType, noProperty.dishonestIntention, noProperty.withoutConsent, noProperty.inPossessionOfAnother, noProperty.propertyMoved) == FALSE

// ----- no dishonest intention: not theft -----

TheftTestCase noIntention := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "none",
    withoutConsent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert noIntention.dishonestIntention == "none"
assert is_theft(noIntention.propertyType, noIntention.dishonestIntention, noIntention.withoutConsent, noIntention.inPossessionOfAnother, noIntention.propertyMoved) == FALSE

// ----- with consent: not theft -----

TheftTestCase withConsent := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    withoutConsent := FALSE,
    inPossessionOfAnother := TRUE,
    propertyMoved := TRUE,
}

assert withConsent.withoutConsent == FALSE
assert is_theft(withConsent.propertyType, withConsent.dishonestIntention, withConsent.withoutConsent, withConsent.inPossessionOfAnother, withConsent.propertyMoved) == FALSE

// ----- not in possession of another: not theft -----

TheftTestCase notInPossession := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    withoutConsent := TRUE,
    inPossessionOfAnother := FALSE,
    propertyMoved := TRUE,
}

assert notInPossession.inPossessionOfAnother == FALSE
assert is_theft(notInPossession.propertyType, notInPossession.dishonestIntention, notInPossession.withoutConsent, notInPossession.inPossessionOfAnother, notInPossession.propertyMoved) == FALSE

// ----- property not moved: not theft -----

TheftTestCase notMoved := TheftTestCase {
    propertyType := "movable_property",
    dishonestIntention := "wrongful_gain",
    withoutConsent := TRUE,
    inPossessionOfAnother := TRUE,
    propertyMoved := FALSE,
}

assert notMoved.propertyMoved == FALSE
assert is_theft(notMoved.propertyType, notMoved.dishonestIntention, notMoved.withoutConsent, notMoved.inPossessionOfAnother, notMoved.propertyMoved) == FALSE
